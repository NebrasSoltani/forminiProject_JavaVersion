<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.formini.controllers.DashboardController"
            prefWidth="1100" prefHeight="700"
            stylesheets="@/css/style.css">

    <!-- Top Navigation Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: white; -fx-padding: 15 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
            <Label text="Espace Évaluation &amp; Quiz" style="-fx-font-size: 22px; -fx-font-weight: 900; -fx-text-fill: #1e293b;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="🔔" style="-fx-background-color: transparent; -fx-font-size: 18px; -fx-cursor: hand;" />
            <HBox alignment="CENTER" spacing="12">
                <Circle radius="18" style="-fx-fill: -fx-primary;" />
                <VBox alignment="CENTER_LEFT">
                    <Label text="Formini User" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 13px;" />
                    <Label text="Connecté" style="-fx-font-size: 11px; -fx-text-fill: #2ed573;" />
                </VBox>
            </HBox>
        </HBox>
    </top>

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar" prefWidth="260" spacing="0">
            
            <!-- Branding -->
            <VBox styleClass="sidebar-logo" alignment="CENTER_LEFT" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="logo-icon-bg">
                        <Label text="F" styleClass="logo-icon-text"/>
                    </StackPane>
                    <VBox spacing="-2">
                        <Label text="Formini.tn" styleClass="logo-text-bold" style="-fx-font-size: 20px;"/>
                        <Label text="MODULE QUIZ" style="-fx-font-size: 10px; -fx-text-fill: -fx-warning; -fx-font-weight: bold; -fx-letter-spacing: 1px;"/>
                    </VBox>
                </HBox>
            </VBox>

            <Separator style="-fx-background-color: rgba(255,255,255,0.05); -fx-border-width: 0;" />

            <!-- Espace Formateur -->
            <VBox spacing="5" style="-fx-padding: 25 0;" VBox.vgrow="ALWAYS">
                <Label text="ESPACE FORMATEUR" style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-font-weight: bold; -fx-padding: 0 0 10 24;"/>
                
                <Button fx:id="btnQuiz" text="📋  Gestion des Quiz" onAction="#ouvrirQuiz" styleClass="nav-sub" maxWidth="Infinity"/>
                <Button fx:id="btnQuestion" text="❓  Gestion des Questions" onAction="#ouvrirQuestion" styleClass="nav-sub" maxWidth="Infinity"/>
                <Button fx:id="btnReponse" text="✅  Gestion des Réponses" onAction="#ouvrirReponse" styleClass="nav-sub" maxWidth="Infinity"/>
                <Button fx:id="btnResultat" text="🏆  Résultats Globaux" onAction="#ouvrirResultat" styleClass="nav-sub" maxWidth="Infinity"/>
                
                <Region prefHeight="30"/>
                
                <!-- Espace Apprenant -->
                <Label text="ESPACE APPRENANT" style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-font-weight: bold; -fx-padding: 0 0 10 24;"/>
                
                <Button fx:id="btnApprenantQuiz" text="📝  Passer un Quiz" onAction="#ouvrirApprenantQuiz" styleClass="nav-sub" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>

    <!-- Main content area -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #f8fafc; -fx-padding: 20;">
            <VBox alignment="CENTER" spacing="15">
                <Label text="Bienvenue dans le Module Quiz" style="-fx-text-fill: #1e293b; -fx-font-size: 32px; -fx-font-weight: 900;"/>
                <Label text="Sélectionnez une option dans le menu de gauche pour démarrer" style="-fx-text-fill: #64748b; -fx-font-size: 16px;"/>
            </VBox>
        </StackPane>
    </center>

</BorderPane>
