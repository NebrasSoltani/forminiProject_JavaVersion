<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.formini.controllers.ApprenantQuizListController"
      spacing="25" style="-fx-background-color: #f8fafc; -fx-padding: 30;">

    <!-- Hero Banner -->
    <HBox spacing="30" alignment="CENTER_LEFT"
          style="-fx-background-color: linear-gradient(to right, #0f172a, #1e293b); -fx-padding: 40; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 5);">
        
        <!-- Left Section: Title & Search -->
        <VBox spacing="15" HBox.hgrow="ALWAYS">
            <Label text="Mes Évaluations" style="-fx-font-size: 32px; -fx-font-weight: 900; -fx-text-fill: white;"/>
            <Label text="Validez vos acquis en passant les quiz de vos formations. Bonne chance !" style="-fx-font-size: 15px; -fx-text-fill: #94a3b8;"/>
            
            <Region prefHeight="10"/>
            
            <!-- Glassmorphism Search Box -->
            <HBox spacing="10" alignment="CENTER_LEFT" maxWidth="450"
                  style="-fx-background-color: rgba(255,255,255,0.1); -fx-padding: 10 15; -fx-background-radius: 12; -fx-border-color: rgba(255,255,255,0.2); -fx-border-radius: 12;">
                <Label text="🔍 Formation ID :" style="-fx-text-fill: #cbd5e1; -fx-font-weight: bold;"/>
                <TextField fx:id="formationIdField" promptText="Ex: 1" text="1" prefWidth="70"
                           style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 6; -fx-border-width: 0 0 1 0;"/>
                <Button text="Charger les Quiz" onAction="#chargerQuiz"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 20;"/>
                <Label fx:id="statusLabel" text="" style="-fx-text-fill: #f87171; -fx-font-size: 12px;"/>
            </HBox>
        </VBox>
        
        <!-- Right Section: Progress Card -->
        <VBox alignment="CENTER" spacing="5" minWidth="200"
              style="-fx-background-color: rgba(0,0,0,0.2); -fx-padding: 25; -fx-background-radius: 16; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 16;">
            <Label text="📈 Ma Progression" style="-fx-text-fill: #cbd5e1; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            <Label fx:id="progressLabel" text="-- / --" style="-fx-text-fill: #34d399; -fx-font-size: 24px; -fx-font-weight: 900;"/>
            <Label text="Leçons terminées" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
        </VBox>
    </HBox>

    <ScrollPane fitToWidth="true" styleClass="scroll-pane" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
        <FlowPane fx:id="quizContainer" hgap="30" vgap="30" prefWrapLength="1080" style="-fx-background-color: transparent; -fx-padding: 5;">
            <!-- Quiz cards dynamiques injectées par le contrôleur -->
        </FlowPane>
    </ScrollPane>

</VBox>
