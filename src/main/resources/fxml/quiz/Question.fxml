<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.formini.controllers.QuestionController"
      spacing="20" VBox.vgrow="ALWAYS"
      style="-fx-background-color: #0f172a; -fx-padding: 28 30;">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="16">

        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Banque de Questions"
                   style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: white;"/>
            <Label text="Gérez les questions affectées aux différents quiz"
                   style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
        </VBox>

        <!-- Search -->
        <TextField fx:id="searchField"
                   promptText="🔍 Rechercher une question..."
                   onKeyReleased="#filtrerQuestions"
                   prefWidth="280"
                   style="-fx-background-color: #1e293b;
                          -fx-text-fill: white;
                          -fx-prompt-text-fill: #475569;
                          -fx-padding: 11 16;
                          -fx-background-radius: 10;
                          -fx-border-color: #334155;
                          -fx-border-radius: 10;
                          -fx-font-size: 13px;"/>

        <!-- Quiz filter -->
        <ComboBox fx:id="filtreQuiz" promptText="Tous les Quiz"
                  onAction="#filtrerQuestions" prefWidth="200"
                  style="-fx-background-color: #1e293b;
                         -fx-border-color: #334155;
                         -fx-border-radius: 10;
                         -fx-background-radius: 10;
                         -fx-padding: 5;"/>

        <!-- Add buttons -->
        <Button text="+ Nouvelle Question" onAction="#ouvrirFormAjout"
                style="-fx-background-color: #0369a1;
                       -fx-text-fill: white;
                       -fx-font-weight: 800;
                       -fx-font-size: 13px;
                       -fx-background-radius: 10;
                       -fx-padding: 11 22;
                       -fx-cursor: hand;"/>
        <Button text="✨ Générer avec IA" onAction="#ouvrirFormIA"
                style="-fx-background-color: #1e293b;
                       -fx-text-fill: #38bdf8;
                       -fx-font-weight: 800;
                       -fx-font-size: 13px;
                       -fx-background-radius: 10;
                       -fx-padding: 11 22;
                       -fx-cursor: hand;
                       -fx-border-color: #334155;
                       -fx-border-radius: 10;"/>
    </HBox>

    <!-- Divider -->
    <Region style="-fx-background-color: #1e293b; -fx-min-height: 1; -fx-max-height: 1;"/>

    <!-- QUESTIONS LIST -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent;
                       -fx-background: #0f172a;
                       -fx-border-color: transparent;">
        <VBox fx:id="questionsContainer" spacing="15"
              style="-fx-padding: 4 0; -fx-background-color: transparent;"/>
    </ScrollPane>

</VBox>
