<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.formini.controllers.quiz.QuizController"
      spacing="25" VBox.vgrow="ALWAYS" style="-fx-background-color: #f8fafc; -fx-padding: 30;">

    <!-- Header Area -->
    <HBox alignment="CENTER_LEFT">
        <VBox spacing="5">
            <Label text="Gestion des Quiz" style="-fx-font-size: 26px; -fx-font-weight: 900; -fx-text-fill: #1e293b;"/>
            <Label text="Administrez les quiz et l'évaluation des apprenants" style="-fx-font-size: 14px; -fx-text-fill: #64748b;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Nouveau Quiz" onAction="#ouvrirFormAjout"
                    style="-fx-background-color: #4f46e5; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 16; -fx-padding: 14 24; -fx-cursor: hand;"/>
            <TextField fx:id="searchField" promptText="🔍 Rechercher un quiz..."
                       onKeyReleased="#filtrerQuiz"
                       prefWidth="350"
                       style="-fx-background-color: #f8fafc; -fx-text-fill: #1e293b; -fx-prompt-text-fill: #94a3b8; -fx-padding: 10 15; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;"/>
        </HBox>

        <!-- Card Container -->
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
            <FlowPane fx:id="quizContainer" hgap="20" vgap="20" prefWrapLength="1080" style="-fx-background-color: transparent; -fx-padding: 5;"/>
        </ScrollPane>
    </VBox>
