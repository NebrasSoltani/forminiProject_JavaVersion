<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.formini.controllers.evenement.EvenementListController"
      spacing="20" styleClass="content-area">

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="📅 Liste des Événements" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="📊 Statistiques" onAction="#showEventStats" style="-fx-background-color: #6974e8; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Button text="➕ Nouvel Événement" onAction="#goToAdd" styleClass="nav-btn-active"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="topbar" style="-fx-background-radius: 10;">
        <TextField fx:id="searchField" promptText="Rechercher par nom..." prefWidth="200"/>
        <ComboBox fx:id="filterType" promptText="Type" prefWidth="150"/>
        <ComboBox fx:id="sortOptions" promptText="Trier par..." prefWidth="150"/>
        <CheckBox fx:id="filterLive" text="Live 🔴"/>
        <CheckBox fx:id="filterActif" text="Actif"/>
        <Button text="Réinitialiser" onAction="#resetFilters" styleClass="icon-btn"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="labelCount" text="0 événement(s)" styleClass="topbar-date"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;">
        <FlowPane fx:id="eventGrid" hgap="25" vgap="25" prefWrapLength="1000" style="-fx-padding: 10;"/>
    </ScrollPane>

    <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 10;">
        <Pagination fx:id="pagination" pageCount="1" maxPageIndicatorCount="5"/>
    </HBox>

</VBox>