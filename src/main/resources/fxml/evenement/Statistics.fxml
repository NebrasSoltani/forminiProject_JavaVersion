<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.formini.controllers.evenement.StatisticsController"
      spacing="20" style="-fx-background-color: #f8fafc; -fx-background-radius: 15; -fx-min-width: 900; -fx-min-height: 700;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="📊 Statistiques Avancées" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
    </HBox>

    <StackPane fx:id="chartContainer" VBox.vgrow="ALWAYS" 
               style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);"/>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button text="Fermer" onAction="#close" 
                style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-padding: 10 25; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>

</VBox>
