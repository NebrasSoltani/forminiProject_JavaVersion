<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.formini.controllers.frontend.ShopController"
      spacing="6" styleClass="content-area"
      prefWidth="740" prefHeight="550">

    <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding: 8 15 0 15;">
        <Label text="Boutique" styleClass="page-title" style="-fx-font-size: 16px;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="labelCartHint" text="Panier vide" style="-fx-text-fill: #334155; -fx-font-weight: bold; -fx-font-size: 11px;"/>
    </HBox>

    <!-- Search and Filter Section -->
    <VBox spacing="6" style="-fx-padding: 0 15 6 15;">
        <HBox spacing="8" alignment="CENTER_LEFT">
            <TextField fx:id="fieldSearch" promptText="Rechercher..." styleClass="search-field" HBox.hgrow="ALWAYS" prefHeight="28"/>
            <Button text="&#128269;" onAction="#searchProducts" styleClass="icon-btn" prefWidth="30" prefHeight="28"/>
        </HBox>
        
        <!-- Category Filter Buttons -->
        <HBox spacing="6" alignment="CENTER_LEFT">
            <Label text="Catégories:" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 11px;"/>
            <HBox spacing="4" HBox.hgrow="ALWAYS">
                <Button text="Tous" onAction="#filterByCategory" styleClass="category-filter-btn" userData="Tous" style="-fx-font-size: 10px; -fx-padding: 3 6;"/>
                <Button text="Info" onAction="#filterByCategory" styleClass="category-filter-btn" userData="Informatique" style="-fx-font-size: 10px; -fx-padding: 3 6;"/>
                <Button text="Science" onAction="#filterByCategory" styleClass="category-filter-btn" userData="Scientifique" style="-fx-font-size: 10px; -fx-padding: 3 6;"/>
                <Button text="Outils" onAction="#filterByCategory" styleClass="category-filter-btn" userData="Outils intelligents" style="-fx-font-size: 10px; -fx-padding: 3 6;"/>
                <Button text="Acc" onAction="#filterByCategory" styleClass="category-filter-btn" userData="Accessoires" style="-fx-font-size: 10px; -fx-padding: 3 6;"/>
            </HBox>
        </HBox>
    </VBox>

    <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS" prefHeight="400">
            <VBox spacing="10">
                <FlowPane fx:id="productsContainer" hgap="15" vgap="15" alignment="TOP_LEFT">
                    <padding>
                        <Insets top="10" left="20" right="20" bottom="10"/>
                    </padding>
                </FlowPane>
                
                <!-- Pagination Controls - Always Visible -->
                <HBox alignment="CENTER" spacing="6" style="-fx-padding: 8 15 12 15; -fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0;">
                    <Button fx:id="btnFirstPage" text="&#171;" onAction="#firstPage" style="-fx-background-color: white; -fx-border-color: #d1d5db; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 4 8; -fx-font-weight: bold; -fx-cursor: hand;" prefWidth="30" prefHeight="25"/>
                    <Button fx:id="btnPreviousPage" text="&#8592;" onAction="#previousPage" style="-fx-background-color: white; -fx-border-color: #d1d5db; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 4 8; -fx-font-weight: bold; -fx-cursor: hand;" prefWidth="30" prefHeight="25"/>
                    
                    <Region HBox.hgrow="ALWAYS"/>
                    
                    <HBox fx:id="pageNumbersContainer" spacing="4" alignment="CENTER"/>
                    
                    <Region HBox.hgrow="ALWAYS"/>
                    
                    <Button fx:id="btnNextPage" text="&#8594;" onAction="#nextPage" style="-fx-background-color: white; -fx-border-color: #d1d5db; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 4 8; -fx-font-weight: bold; -fx-cursor: hand;" prefWidth="30" prefHeight="25"/>
                    <Button fx:id="btnLastPage" text="&#187;" onAction="#lastPage" style="-fx-background-color: white; -fx-border-color: #d1d5db; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 4 8; -fx-font-weight: bold; -fx-cursor: hand;" prefWidth="30" prefHeight="25"/>
                </HBox>
            </VBox>
        </ScrollPane>
</VBox>

