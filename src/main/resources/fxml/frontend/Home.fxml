<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>
<?import java.net.URL?>

<!--
    Page d'accueil publique de Formini.
    Structure :
      1. Hero section
      2. Barre de filtrage par type d'événement
      3. Section Événements → ScrollPane horizontal de cartes
-->
<ScrollPane fitToWidth="true"
            vbarPolicy="AS_NEEDED" hbarPolicy="NEVER"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.formini.controllers.frontend.HomeController"
            style="-fx-background-color: #f8fafc; -fx-background: #f8fafc;">

    <stylesheets>
        <URL value="@/css/style.css"/>
        <URL value="@/css/home-cards.css"/>
    </stylesheets>

    <VBox spacing="45" style="-fx-background-color: #f8fafc;">
        <padding><Insets top="40" right="50" bottom="60" left="50"/></padding>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!--  HERO SECTION                                                  -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <VBox styleClass="hero-section" spacing="30" alignment="CENTER_LEFT">
            <VBox spacing="12">
                <Label text="Bienvenue sur Formini.tn"
                       style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: bold; -fx-font-size: 17px;"/>
                <TextFlow lineSpacing="6">
                    <Text text="Formations " styleClass="hero-title"/>
                    <Text text="certifiantes" styleClass="hero-title"
                          style="-fx-fill: #ffa502; -fx-font-style: italic;"/>
                    <Text text=" avec des " styleClass="hero-title"/>
                    <Text text="experts" styleClass="hero-title" style="-fx-fill: #ffa502;"/>
                </TextFlow>
                <Label text="Développez vos compétences avec des formateurs expérimentés."
                       styleClass="hero-subtitle" wrapText="true" maxWidth="700"/>
            </VBox>

            <!-- Stats -->
            <HBox spacing="40" alignment="CENTER_LEFT" styleClass="hero-stats-container">
                <VBox styleClass="stat-item">
                    <Label text="5000+" styleClass="stat-value"/>
                    <Label text="Apprenants" styleClass="stat-label"/>
                </VBox>
                <Separator orientation="VERTICAL" styleClass="stat-sep" prefHeight="40"/>
                <VBox styleClass="stat-item">
                    <Label text="120+" styleClass="stat-value"/>
                    <Label text="Formations" styleClass="stat-label"/>
                </VBox>
                <Separator orientation="VERTICAL" styleClass="stat-sep" prefHeight="40"/>
                <VBox styleClass="stat-item">
                    <Label text="98%" styleClass="stat-value"/>
                    <Label text="Satisfaction" styleClass="stat-label"/>
                </VBox>
            </HBox>

            <HBox spacing="20">
                <Button text="Rejoindre Formini" styleClass="main-button-onix"
                        style="-fx-background-color: -fx-accent; -fx-padding: 16 40; -fx-font-size: 15px;"/>
                <Button text="Nos Formations" styleClass="main-button-onix"
                        style="-fx-background-color: transparent; -fx-border-color: white;
                               -fx-border-radius: 25; -fx-padding: 16 40; -fx-font-size: 15px;"/>
            </HBox>
        </VBox>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!--  BARRE DE FILTRAGE PAR TYPE                                    -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 16;
                     -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.07), 12, 0, 0, 3);
                     -fx-padding: 22 28;">

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="🔍" style="-fx-font-size: 20px;"/>
                <VBox spacing="2">
                    <Label text="Filtrer par type d'événement"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Sélectionnez un type pour affiner les résultats"
                           style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
                </VBox>
            </HBox>

            <HBox spacing="15" alignment="CENTER_LEFT">
                <VBox.margin><Insets top="14"/></VBox.margin>

                <ComboBox fx:id="filterCombo"
                          promptText="Choisir un type…"
                          prefWidth="300"
                          style="-fx-font-size: 13px; -fx-padding: 8 12;"/>

                <Button text="✕  Tout afficher"
                        onAction="#toutAfficher"
                        style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-padding: 9 20; -fx-background-radius: 10; -fx-cursor: hand;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="labelResultats"
                       style="-fx-font-size: 12px; -fx-text-fill: #94a3b8; -fx-font-style: italic;"/>
            </HBox>
        </VBox>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!--  SECTION ÉVÉNEMENTS                                            -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <VBox spacing="18">
            <!-- En-tête section -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="📅" style="-fx-font-size: 22px;"/>
                <VBox spacing="3">
                    <Label text="WEBINAIRES &amp; SESSIONS LIVE"
                           style="-fx-font-size: 11px; -fx-font-weight: bold;
                                  -fx-text-fill: #10b981; -fx-letter-spacing: 1.5px;"/>
                    <Label text="Nos prochains Événements"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                </VBox>
            </HBox>

            <!-- ScrollPane horizontal — scrollbar invisible -->
            <ScrollPane hbarPolicy="NEVER" vbarPolicy="NEVER"
                        fitToHeight="true"
                        style="-fx-background-color: transparent; -fx-background: transparent;
                               -fx-padding: 4 0 10 0;">
                <HBox fx:id="eventCardsBox" spacing="20" alignment="CENTER_LEFT">
                    <padding><Insets top="6" bottom="12" left="2" right="10"/></padding>
                </HBox>
            </ScrollPane>
        </VBox>

    </VBox>
</ScrollPane>
