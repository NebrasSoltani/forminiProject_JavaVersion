<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.formini.controllers.blog.BlogListController"
      spacing="20" styleClass="content-area">

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="📝 Liste des Blogs" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="➕ Nouveau Blog" onAction="#goToAdd" styleClass="nav-btn-active"/>
    </HBox>

    <!-- Filters -->
    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="topbar" style="-fx-background-radius: 10;">
        <TextField fx:id="searchField" promptText="Rechercher par titre..." prefWidth="250"/>
        <ComboBox fx:id="filterCategorie" promptText="Catégorie"/>
        <ComboBox fx:id="filterStatus" promptText="Statut"/>
        <Button text="Réinitialiser" onAction="#resetFilters" styleClass="icon-btn"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="labelCount" text="0 blog(s)" styleClass="topbar-date"/>
    </HBox>

    <TableView fx:id="tableBlogs" VBox.vgrow="ALWAYS" styleClass="modern-table">
        <columns>
            <TableColumn fx:id="colCategorie" text="Catégorie" prefWidth="100" styleClass="cell-title"/>
            <TableColumn fx:id="colTitre" text="Titre" prefWidth="450"/>
            <TableColumn fx:id="colAuteur" text="Auteur" prefWidth="130"/>
            <TableColumn fx:id="colStatus" text="Statut" prefWidth="100"/>
            <TableColumn fx:id="colActions" text="Actions" prefWidth="120" styleClass="cell-actions"/>
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Pagination fx:id="pagination" pageCount="10" maxPageIndicatorCount="5"/>
    </HBox>

</VBox>