<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.formini.controllers.order.OrderDetailsController"
      spacing="20" style="-fx-background-color: #f8fafc; -fx-padding: 20;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
        <VBox spacing="5">
            <Label fx:id="orderNumberLabel" text="Commande #000000" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="Détails de la commande" style="-fx-font-size: 14; -fx-text-fill: #64748b;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Fermer" onAction="#closeDetails" style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 20; -fx-font-weight: 500;"/>
    </HBox>

    <!-- Order Details -->
    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <VBox spacing="20">
            <!-- Customer Information -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                <Label text="Informations Client" style="-fx-font-size: 16; -fx-font-weight: 600; -fx-text-fill: #1e293b;"/>
                
                <GridPane hgap="15" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="150"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
                    </columnConstraints>
                    
                    <Label text="Nom:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: 500; -fx-text-fill: #374151;"/>
                    <Label fx:id="customerNameLabel" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-text-fill: #1f2937;"/>
                    
                    <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: 500; -fx-text-fill: #374151;"/>
                    <Label fx:id="customerEmailLabel" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-text-fill: #1f2937;"/>
                    
                    <Label text="Téléphone:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: 500; -fx-text-fill: #374151;"/>
                    <Label fx:id="customerPhoneLabel" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-text-fill: #1f2937;"/>
                    
                    <Label text="Adresse:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: 500; -fx-text-fill: #374151;"/>
                    <Label fx:id="shippingAddressLabel" GridPane.columnIndex="1" GridPane.rowIndex="3" style="-fx-text-fill: #1f2937; -fx-wrap-text: true;"/>
                </GridPane>
            </VBox>

            <!-- Order Information -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                <Label text="Informations Commande" style="-fx-font-size: 16; -fx-font-weight: 600; -fx-text-fill: #1e293b;"/>
                
                <GridPane hgap="15" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="150"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
                    </columnConstraints>
                    
                    <Label text="Montant total:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: 500; -fx-text-fill: #374151;"/>
                    <Label fx:id="totalAmountLabel" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-text-fill: #059669; -fx-font-weight: 600;"/>
                    
                    <Label text="Statut:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: 500; -fx-text-fill: #374151;"/>
                    <Label fx:id="statusLabel" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-text-fill: #1f2937;"/>
                    
                    <Label text="Date de commande:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: 500; -fx-text-fill: #374151;"/>
                    <Label fx:id="orderDateLabel" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-text-fill: #1f2937;"/>
                    
                    <Label text="Date de livraison:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: 500; -fx-text-fill: #374151;"/>
                    <Label fx:id="deliveryDateLabel" GridPane.columnIndex="1" GridPane.rowIndex="3" style="-fx-text-fill: #1f2937;"/>
                    
                    <Label text="Nombre d'articles:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: 500; -fx-text-fill: #374151;"/>
                    <Label fx:id="itemCountLabel" GridPane.columnIndex="1" GridPane.rowIndex="4" style="-fx-text-fill: #1f2937;"/>
                    
                    <Label text="Articles:" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-font-weight: 500; -fx-text-fill: #374151;"/>
                    <Label fx:id="itemsDescriptionLabel" GridPane.columnIndex="1" GridPane.rowIndex="5" style="-fx-text-fill: #1f2937; -fx-wrap-text: true;"/>
                </GridPane>
            </VBox>

            <!-- Payment Information -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                <Label text="Informations Paiement" style="-fx-font-size: 16; -fx-font-weight: 600; -fx-text-fill: #1e293b;"/>
                
                <GridPane hgap="15" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="150"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
                    </columnConstraints>
                    
                    <Label text="Méthode de paiement:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: 500; -fx-text-fill: #374151;"/>
                    <Label fx:id="paymentMethodLabel" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-text-fill: #1f2937;"/>
                    
                    <Label text="Statut de paiement:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: 500; -fx-text-fill: #374151;"/>
                    <Label fx:id="paymentStatusLabel" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-text-fill: #1f2937;"/>
                </GridPane>
            </VBox>

            <!-- Notes -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                <Label text="Notes" style="-fx-font-size: 16; -fx-font-weight: 600; -fx-text-fill: #1e293b;"/>
                <Label fx:id="notesLabel" style="-fx-text-fill: #1f2937; -fx-wrap-text: true;" prefHeight="60"/>
            </VBox>

        </VBox>
    </ScrollPane>

</VBox>
