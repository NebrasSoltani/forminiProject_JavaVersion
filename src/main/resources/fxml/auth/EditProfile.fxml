<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.formini.controllers.auth.EditProfileController" spacing="15" style="-fx-padding: 20;">
    <children>
        <Label text="Modifier le Profil" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        
        <GridPane hgap="10" vgap="10">
            <children>
                <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="emailTextField" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="300"/>
                
                <Label text="Nom:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="nomTextField" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="300"/>
                
                <Label text="Prénom:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextField fx:id="prenomTextField" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="300"/>
                
                <Label text="Téléphone:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <TextField fx:id="telephoneTextField" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="300"/>
                
                <Label text="Gouvernorat:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <ComboBox fx:id="gouvernoratComboBox" GridPane.columnIndex="1" GridPane.rowIndex="4" prefWidth="300"/>
                
                <Label text="Date de naissance:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                <DatePicker fx:id="dateNaissanceField" GridPane.columnIndex="1" GridPane.rowIndex="5" prefWidth="300"/>
            </children>
        </GridPane>
        
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <children>
                <Button fx:id="saveButton" text="Enregistrer" onAction="#handleSaveButton"/>
                <Button fx:id="cancelButton" text="Annuler" onAction="#handleCancelButton"/>
            </children>
        </HBox>
    </children>
</VBox>
