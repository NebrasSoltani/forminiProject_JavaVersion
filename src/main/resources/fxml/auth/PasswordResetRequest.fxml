<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.formini.controllers.auth.PasswordResetRequestController"
      spacing="18"
      styleClass="signup-page"
      alignment="CENTER">

    <padding>
        <Insets top="48" right="48" bottom="48" left="48"/>
    </padding>

    <Label text="Reset Password" styleClass="login-title"/>

    <Label text="Enter your email address to receive a password reset token" 
           styleClass="login-subtitle" wrapText="true" textAlignment="CENTER"/>

    <VBox spacing="12" maxWidth="350">
        <VBox spacing="4">
            <Label text="Email" styleClass="form-label"/>
            <TextField fx:id="fieldEmail" promptText="Enter your email" styleClass="form-control"/>
            <Label fx:id="errorEmail" styleClass="error-label" text="" visible="false" managed="false"/>
        </VBox>

        <Button fx:id="btnSendReset" text="Send Reset Token" styleClass="login-btn-primary" onAction="#onSendReset"/>

        <Button fx:id="btnBackToLogin" text="Back to Login" styleClass="login-btn-secondary" onAction="#onBackToLogin"/>

        <Label fx:id="lblMessage" styleClass="login-alert" text="" visible="false" managed="false" wrapText="true" textAlignment="CENTER"/>
    </VBox>
</VBox>
