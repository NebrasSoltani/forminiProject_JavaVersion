<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.formini.controllers.auth.NewPasswordController"
      spacing="18"
      styleClass="signup-page"
      alignment="CENTER">

    <padding>
        <Insets top="48" right="48" bottom="48" left="48"/>
    </padding>

    <Label text="Set New Password" styleClass="login-title"/>

    <Label text="Enter the reset token and your new password" 
           styleClass="login-subtitle" wrapText="true" textAlignment="CENTER"/>

    <VBox spacing="12" maxWidth="350">
        <VBox spacing="4">
            <Label text="Reset Token" styleClass="form-label"/>
            <TextField fx:id="fieldToken" promptText="Enter the token from email" styleClass="form-control"/>
            <Label fx:id="errorToken" styleClass="error-label" text="" visible="false" managed="false"/>
        </VBox>

        <VBox spacing="4">
            <Label text="New Password" styleClass="form-label"/>
            <PasswordField fx:id="fieldPassword" promptText="Enter new password" styleClass="form-control"/>
            <Label fx:id="errorPassword" styleClass="error-label" text="" visible="false" managed="false"/>
        </VBox>

        <VBox spacing="4">
            <Label text="Confirm Password" styleClass="form-label"/>
            <PasswordField fx:id="fieldPasswordConfirm" promptText="Confirm new password" styleClass="form-control"/>
            <Label fx:id="errorPasswordConfirm" styleClass="error-label" text="" visible="false" managed="false"/>
        </VBox>

        <Button fx:id="btnResetPassword" text="Reset Password" styleClass="login-btn-primary" onAction="#onResetPassword"/>

        <Button fx:id="btnBackToLogin" text="Back to Login" styleClass="login-btn-secondary" onAction="#onBackToLogin"/>

        <Label fx:id="lblMessage" styleClass="login-alert" text="" visible="false" managed="false" wrapText="true" textAlignment="CENTER"/>
    </VBox>
</VBox>
