<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.formini.controllers.crud.SocieteFormController" spacing="15" style="-fx-padding: 20;">
    <children>
        <Label text="Formulaire Société" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        
        <GridPane hgap="10" vgap="10">
            <children>
                <Label text="Nom de la société*:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="nomTextField" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="300"/>
                
                <Label text="Utilisateur*:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <ComboBox fx:id="userComboBox" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="300"/>
                
                <Label text="Secteur:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextField fx:id="secteurTextField" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="300"/>
                
                <Label text="Adresse:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <TextField fx:id="adresseTextField" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="300"/>
                
                <Label text="Site Web:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <TextField fx:id="siteWebTextField" GridPane.columnIndex="1" GridPane.rowIndex="4" prefWidth="300" promptText="https://..."/>
                
                <Label text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                <TextArea fx:id="descriptionTextArea" GridPane.columnIndex="1" GridPane.rowIndex="5" prefWidth="300" prefHeight="100" promptText="Description de la société..."/>
            </children>
        </GridPane>
        
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <children>
                <Button fx:id="saveButton" text="Enregistrer" onAction="#handleSaveButton"/>
                <Button fx:id="cancelButton" text="Annuler" onAction="#handleCancelButton"/>
            </children>
        </HBox>
    </children>
</VBox>
