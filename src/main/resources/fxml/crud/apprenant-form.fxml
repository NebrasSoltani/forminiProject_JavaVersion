<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.formini.controllers.crud.ApprenantFormController" spacing="15" style="-fx-padding: 20;">
    <children>
        <Label text="Formulaire Apprenant" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        
        <GridPane hgap="10" vgap="10">
            <children>
                <Label text="Genre:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <ComboBox fx:id="genreComboBox" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="200"/>
                
                <Label text="État Civil:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <ComboBox fx:id="etatCivilComboBox" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="200"/>
                
                <Label text="Utilisateur:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <ComboBox fx:id="userComboBox" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="200"/>
                
                <Label text="Domaine:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <ComboBox fx:id="domaineComboBox" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="200"/>
                
                <Label text="Objectif:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <TextArea fx:id="objectifTextArea" GridPane.columnIndex="1" GridPane.rowIndex="4" prefWidth="300" prefHeight="80" promptText="Objectif de l'apprenant..."/>
                
                <Label text="Domaines d'intérêt:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                <TextArea fx:id="domainesInteretTextArea" GridPane.columnIndex="1" GridPane.rowIndex="5" prefWidth="300" prefHeight="80" promptText="[&quot;domaine1&quot;, &quot;domaine2&quot;]"/>
            </children>
        </GridPane>
        
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <children>
                <Button fx:id="saveButton" text="Enregistrer" onAction="#handleSaveButton"/>
                <Button fx:id="cancelButton" text="Annuler" onAction="#handleCancelButton"/>
            </children>
        </HBox>
    </children>
</VBox>
