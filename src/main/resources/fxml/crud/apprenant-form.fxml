<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.formini.controllers.crud.ApprenantFormController" spacing="15" style="-fx-padding: 20;">
    <children>
        <Label text="Formulaire Apprenant" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        
        <GridPane hgap="10" vgap="10">
            <children>
                <Label text="Nom*:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="nomTextField" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="300"/>
                
                <Label text="Prénom*:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="prenomTextField" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="300"/>
                
                <Label text="Email*:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextField fx:id="emailTextField" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="300"/>
                
                <Label text="Téléphone*:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <TextField fx:id="telephoneTextField" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="300"/>
                
                <Label text="Date de naissance*:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <DatePicker fx:id="dateNaissanceField" GridPane.columnIndex="1" GridPane.rowIndex="4" prefWidth="300"/>
                
                <Label text="Genre:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                <ComboBox fx:id="genreComboBox" GridPane.columnIndex="1" GridPane.rowIndex="5" prefWidth="300"/>
                
                <Label text="État civil:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                <ComboBox fx:id="etatCivilComboBox" GridPane.columnIndex="1" GridPane.rowIndex="6" prefWidth="300"/>
                
                <Label text="Objectif:" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                <TextField fx:id="objectifTextField" GridPane.columnIndex="1" GridPane.rowIndex="7" prefWidth="300"/>
                
                <Label text="Domaines d'intérêt:" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
                <TextArea fx:id="domainesInteretTextArea" GridPane.columnIndex="1" GridPane.rowIndex="8" prefWidth="300" prefHeight="100"/>
            </children>
        </GridPane>
        
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <children>
                <Button fx:id="saveButton" text="Enregistrer" onAction="#handleSaveButton"/>
                <Button fx:id="cancelButton" text="Annuler" onAction="#handleCancelButton"/>
            </children>
        </HBox>
    </children>
</VBox>
