<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.formini.controllers.crud.SocieteCrudController" 
      style="-fx-background-color: #f8f9fa; -fx-padding: 20;" spacing="15">
    
    <!-- Header Section -->
    <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e9ecef; -fx-border-width: 1; -fx-padding: 20;">
        <children>
            <HBox alignment="CENTER_LEFT" spacing="15">
                <children>
                    <Button fx:id="backButton" text="← Retour" onAction="#handleBackButton" 
                            prefWidth="100" prefHeight="35"
                            style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    <Label text="Gestion des Sociétés" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="countLabel" text="Total: 0 sociétés" style="-fx-font-size: 14px; -fx-text-fill: #6c757d; -fx-background-color: #e9ecef; -fx-background-radius: 20; -fx-padding: 5 15;"/>
                </children>
            </HBox>
            <Label text="Gérez les informations des sociétés, leurs secteurs d'activité et coordonnées" 
                   style="-fx-font-size: 14px; -fx-text-fill: #6c757d; -fx-padding: 5 0 0 0;"/>
        </children>
    </VBox>
    
    <!-- Search and Actions Section -->
    <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e9ecef; -fx-border-width: 1; -fx-padding: 20;" spacing="15">
        <children>
            <!-- Search Bar -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <children>
                    <TextField fx:id="searchField" promptText="Rechercher par ID, nom, secteur ou email..." 
                             prefWidth="300" prefHeight="40" 
                             style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ced4da; -fx-border-width: 1; -fx-padding: 0 12;">
                        <HBox.margin>
                            <Insets/>
                        </HBox.margin>
                    </TextField>
                    <Button fx:id="searchButton" text="Rechercher" onAction="#handleSearch" 
                            prefWidth="100" prefHeight="40"
                            style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;"/>
                </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <children>
                    <ComboBox fx:id="searchScopeComboBox" prefWidth="170" prefHeight="36" promptText="Champ recherche"/>
                    <TextField fx:id="secteurFilterField" prefWidth="170" prefHeight="36" promptText="Filtre secteur"/>
                    <CheckBox fx:id="hasWebsiteCheckBox" text="Avec site web"/>
                    <ComboBox fx:id="sortByComboBox" prefWidth="150" prefHeight="36" promptText="Trier par"/>
                    <ComboBox fx:id="sortDirectionComboBox" prefWidth="140" prefHeight="36" promptText="Sens"/>
                    <Button fx:id="filterButton" text="Filtrer" onAction="#handleFilter"
                            prefWidth="92" prefHeight="36"
                            styleClass="btn-filter"/>
                    <Button fx:id="sortButton" text="Trier" onAction="#handleSort"
                            prefWidth="88" prefHeight="36"
                            styleClass="btn-sort"/>
                    <Button fx:id="resetFiltersButton" text="Réinitialiser" onAction="#handleResetFilters"
                            prefWidth="120" prefHeight="36"
                            styleClass="btn-reset-filters"/>
                </children>
            </HBox>
            
            <!-- Action Buttons -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <children>
                    <Button fx:id="addButton" text="+ Ajouter une Société" onAction="#handleAddButton" 
                            prefWidth="180" prefHeight="40"
                            style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="viewDetailsButton" text="Voir Détails" onAction="#handleViewDetailsButton" disable="true"
                            prefWidth="120" prefHeight="40"
                            style="-fx-background-color: #17a2b8; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    <Button fx:id="editButton" text="Modifier" onAction="#handleEditButton" disable="true"
                            prefWidth="100" prefHeight="40"
                            style="-fx-background-color: #ffc107; -fx-text-fill: #212529; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    <Button fx:id="deleteButton" text="Supprimer" onAction="#handleDeleteButton" disable="true"
                            prefWidth="100" prefHeight="40"
                            style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    <Button fx:id="refreshButton" text="Actualiser" onAction="#handleRefreshButton" 
                            prefWidth="100" prefHeight="40"
                            style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;"/>
                </children>
            </HBox>
        </children>
    </VBox>
    
    <!-- Table Section -->
    <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e9ecef; -fx-border-width: 1; -fx-padding: 5;">
        <children>
            <TableView fx:id="tableView" VBox.vgrow="ALWAYS" 
                       style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="60" style="-fx-alignment: CENTER; -fx-font-weight: bold;"/>
                    <TableColumn fx:id="nomColumn" text="Nom de la Société" prefWidth="200"/>
                    <TableColumn fx:id="secteurColumn" text="Secteur" prefWidth="120"/>
                    <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="200"/>
                    <TableColumn fx:id="adresseColumn" text="Adresse" prefWidth="150"/>
                    <TableColumn fx:id="siteWebColumn" text="Site Web" prefWidth="150"/>
                    <TableColumn fx:id="userEmailColumn" text="Email" prefWidth="200"/>
                </columns>
            </TableView>
            <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10 10 5 10;">
                <children>
                    <Pagination fx:id="pagination" pageCount="1" maxPageIndicatorCount="5"/>
                </children>
            </HBox>
        </children>
    </VBox>
    
    <!-- Status Bar -->
    <HBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e9ecef; -fx-border-width: 1; -fx-padding: 10 20;" 
          alignment="CENTER_LEFT" spacing="20">
        <children>
            <Label fx:id="statusLabel" text="Prêt" style="-fx-font-size: 12px; -fx-text-fill: #6c757d;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lastUpdateLabel" text="Dernière mise à jour: --:--" style="-fx-font-size: 12px; -fx-text-fill: #6c757d;"/>
        </children>
    </HBox>
    
</VBox>
