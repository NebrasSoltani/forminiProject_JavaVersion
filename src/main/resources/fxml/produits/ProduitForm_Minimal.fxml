<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.formini.controllers.produits.ProduitFormController"
      spacing="10" style="-fx-padding: 20;">
    
    <Label text="PRODUCT FORM" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    
    <TextField fx:id="fieldNom" promptText="Product Name"/>
    <ComboBox fx:id="fieldCategorie" promptText="Category"/>
    <TextField fx:id="fieldPrix" promptText="Price"/>
    <TextField fx:id="fieldStock" promptText="Stock"/>
    <DatePicker fx:id="fieldDateCreation"/>
    <ComboBox fx:id="fieldStatut" promptText="Status"/>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="fieldImage" promptText="Image URL" HBox.hgrow="ALWAYS"/>
        <Button text="📁 Browse" onAction="#browseImage" style="-fx-background-color: #667eea; -fx-text-fill: white;"/>
    </HBox>
    <TextArea fx:id="fieldDescription" promptText="Description" prefHeight="60"/>
    
    <Button fx:id="btnSave" text="Save" onAction="#saveProduit"/>
    <Button text="Cancel" onAction="#goBack"/>
    
    <!-- Hidden error labels -->
    <Label fx:id="errNom" visible="false"/>
    <Label fx:id="errCategorie" visible="false"/>
    <Label fx:id="errDescription" visible="false"/>
    <Label fx:id="errPrix" visible="false"/>
    <Label fx:id="errStock" visible="false"/>
    <Label fx:id="errDateCreation" visible="false"/>
    <Label fx:id="errStatut" visible="false"/>
    <Label fx:id="validationSummary" visible="false"/>
    <VBox fx:id="validationCard" visible="false"/>
    
</VBox>
