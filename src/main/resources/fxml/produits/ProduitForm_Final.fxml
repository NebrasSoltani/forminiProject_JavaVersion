<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.formini.controllers.produits.ProduitFormController"
      spacing="20" style="-fx-background-color: #667eea; -fx-padding: 20;">
    
    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Button text="←" onAction="#goBack" style="-fx-background-color: white; -fx-text-fill: #667eea; -fx-background-radius: 50; -fx-pref-width: 40; -fx-pref-height: 40; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        <VBox spacing="5">
            <Label fx:id="labelFormTitle" text="Ajouter un Produit" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Remplissez les informations ci-dessous" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.8);"/>
        </VBox>
    </HBox>

    <!-- Form Content -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" style="-fx-background: transparent;">
        <VBox spacing="20">
            
            <!-- Basic Information -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 20, 0, 0, 10);">
                <Label text="Informations de base" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                
                <GridPane hgap="20" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="250" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="250" />
                    </columnConstraints>
                    
                    <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="Nom du produit" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4a5568;"/>
                        <TextField fx:id="fieldNom" promptText="Ex: MacBook Pro 14\"" prefHeight="45" style="-fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10;"/>
                        <Label fx:id="errNom" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px; -fx-font-weight: 500;" visible="false"/>
                    </VBox>

                    <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="Catégorie" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4a5568;"/>
                        <ComboBox fx:id="fieldCategorie" maxWidth="Infinity" promptText="Sélectionnez une catégorie" prefHeight="45" style="-fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10;"/>
                        <Label fx:id="errCategorie" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px; -fx-font-weight: 500;" visible="false"/>
                    </VBox>

                    <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                        <Label text="Description" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4a5568;"/>
                        <TextArea fx:id="fieldDescription" prefHeight="100" promptText="Décrivez les caractéristiques, avantages et utilisation du produit..." wrapText="true" style="-fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10;"/>
                        <Label fx:id="errDescription" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px; -fx-font-weight: 500;" visible="false"/>
                    </VBox>
                </GridPane>
            </VBox>

            <!-- Pricing & Inventory -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 20, 0, 0, 10);">
                <Label text="Prix et Stock" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                
                <GridPane hgap="20" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="250" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="250" />
                    </columnConstraints>
                    
                    <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="Prix unitaire (DT)" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4a5568;"/>
                        <TextField fx:id="fieldPrix" promptText="0.000" prefHeight="45" style="-fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10;"/>
                        <Label fx:id="errPrix" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px; -fx-font-weight: 500;" visible="false"/>
                    </VBox>

                    <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="Quantité en stock" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4a5568;"/>
                        <TextField fx:id="fieldStock" promptText="0" prefHeight="45" style="-fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10;"/>
                        <Label fx:id="errStock" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px; -fx-font-weight: 500;" visible="false"/>
                    </VBox>
                </GridPane>
            </VBox>

            <!-- Status & Date -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 20, 0, 0, 10);">
                <Label text="Statut et Date" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                
                <GridPane hgap="20" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="250" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="250" />
                    </columnConstraints>
                    
                    <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="Date de création" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4a5568;"/>
                        <DatePicker fx:id="fieldDateCreation" maxWidth="Infinity" promptText="Sélectionnez une date" prefHeight="45" style="-fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10;"/>
                        <Label fx:id="errDateCreation" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px; -fx-font-weight: 500;" visible="false"/>
                    </VBox>

                    <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="Statut" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4a5568;"/>
                        <ComboBox fx:id="fieldStatut" maxWidth="Infinity" promptText="Sélectionnez le statut" prefHeight="45" style="-fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10;"/>
                        <Label fx:id="errStatut" style="-fx-text-fill: #e53e3e; -fx-font-size: 12px; -fx-font-weight: 500;" visible="false"/>
                    </VBox>
                </GridPane>
            </VBox>

            <!-- Media -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 20, 0, 0, 10);">
                <Label text="Image du produit" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                
                <VBox spacing="8">
                    <Label text="URL de l'image" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4a5568;"/>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <TextField fx:id="fieldImage" promptText="https://example.com/image.jpg" HBox.hgrow="ALWAYS" prefHeight="45" style="-fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 10;"/>
                        <Button text="📁" onAction="#browseImage" style="-fx-background-color: #9f7aea; -fx-text-fill: white; -fx-background-radius: 8; -fx-pref-width: 45; -fx-pref-height: 45; -fx-font-size: 18px;"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- Validation Summary -->
            <VBox fx:id="validationCard" spacing="12" style="-fx-background-color: #fed7d7; -fx-background-radius: 10; -fx-padding: 20; -fx-border-color: #fc8181; -fx-border-width: 1;" visible="false">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="" style="-fx-text-fill: #e53e3e; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Label text="Veuillez corriger les erreurs suivantes:" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #c53030;"/>
                </HBox>
                <Label fx:id="validationSummary" style="-fx-font-size: 13px; -fx-text-fill: #742a2a; -fx-wrap-text: true;"/>
            </VBox>

        </VBox>
    </ScrollPane>

    <!-- Action Buttons -->
    <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 0 20 20 20;">
        <Button text="Annuler" onAction="#goBack" style="-fx-background-color: white; -fx-text-fill: #667eea; -fx-border-color: #667eea; -fx-border-width: 2; -fx-background-radius: 25; -fx-padding: 12 30; -fx-font-size: 14px; -fx-font-weight: 600;"/>
        <Button fx:id="btnSave" text="💾 Enregistrer le produit" onAction="#saveProduit" style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-border-color: transparent; -fx-background-radius: 25; -fx-padding: 12 35; -fx-font-size: 14px; -fx-font-weight: 600;"/>
    </HBox>

</VBox>
