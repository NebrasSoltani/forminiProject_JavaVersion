<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.formini.controllers.produits.ProduitFormController"
      spacing="0" style="-fx-background-color: #f8fafc;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: linear-gradient(to right, #4f46e5, #7c3aed); -fx-padding: 24 32; -fx-background-radius: 16 16 0 0;">
        <VBox spacing="4">
            <Label text="Ajouter un Produit" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Remplissez les informations du nouveau produit" style="-fx-font-size: 14; -fx-text-fill: rgba(255,255,255,0.8);"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="×" onAction="#goBack" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-background-radius: 50%; -fx-pref-width: 40; -fx-pref-height: 40; -fx-font-size: 20; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>

    <!-- Main Content -->
    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 32 32 24 32;">
        <VBox spacing="24">
            
            <!-- Product Information Card -->
            <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 4);">
                <Label text="Informations du Produit" style="-fx-font-size: 18; -fx-font-weight: 600; -fx-text-fill: #1e293b;"/>
                
                <GridPane hgap="20" vgap="16">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="250"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="250"/>
                    </columnConstraints>
                    
                    <!-- Product Name -->
                    <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="6">
                        <Label text="Nom du produit *" style="-fx-font-weight: 500; -fx-text-fill: #374151;"/>
                        <TextField fx:id="fieldNom" style="-fx-pref-height: 48; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-padding: 0 16; -fx-font-size: 14;"/>
                        <Label fx:id="errNom" style="-fx-text-fill: #ef4444; -fx-font-size: 12; -fx-wrap-text: true;" visible="false"/>
                    </VBox>
                    
                    <!-- Category -->
                    <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="6">
                        <Label text="Catégorie *" style="-fx-font-weight: 500; -fx-text-fill: #374151;"/>
                        <ComboBox fx:id="fieldCategorie" style="-fx-pref-height: 48; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-padding: 0 16; -fx-font-size: 14;"/>
                        <Label fx:id="errCategorie" style="-fx-text-fill: #ef4444; -fx-font-size: 12; -fx-wrap-text: true;" visible="false"/>
                    </VBox>
                    
                    <!-- Price -->
                    <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="6">
                        <Label text="Prix (DT) *" style="-fx-font-weight: 500; -fx-text-fill: #374151;"/>
                        <TextField fx:id="fieldPrix" style="-fx-pref-height: 48; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-padding: 0 16; -fx-font-size: 14;"/>
                        <Label fx:id="errPrix" style="-fx-text-fill: #ef4444; -fx-font-size: 12; -fx-wrap-text: true;" visible="false"/>
                    </VBox>
                    
                    <!-- Stock -->
                    <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" spacing="6">
                        <Label text="Stock *" style="-fx-font-weight: 500; -fx-text-fill: #374151;"/>
                        <TextField fx:id="fieldStock" style="-fx-pref-height: 48; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-padding: 0 16; -fx-font-size: 14;"/>
                        <Label fx:id="errStock" style="-fx-text-fill: #ef4444; -fx-font-size: 12; -fx-wrap-text: true;" visible="false"/>
                    </VBox>
                    
                    <!-- Creation Date -->
                    <VBox GridPane.columnIndex="0" GridPane.rowIndex="2" spacing="6">
                        <Label text="Date de création *" style="-fx-font-weight: 500; -fx-text-fill: #374151;"/>
                        <DatePicker fx:id="fieldDateCreation" style="-fx-pref-height: 48; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-padding: 0 16; -fx-font-size: 14;"/>
                        <Label fx:id="errDateCreation" style="-fx-text-fill: #ef4444; -fx-font-size: 12; -fx-wrap-text: true;" visible="false"/>
                    </VBox>
                    
                    <!-- Status -->
                    <VBox GridPane.columnIndex="1" GridPane.rowIndex="2" spacing="6">
                        <Label text="Statut *" style="-fx-font-weight: 500; -fx-text-fill: #374151;"/>
                        <ComboBox fx:id="fieldStatut" style="-fx-pref-height: 48; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-padding: 0 16; -fx-font-size: 14;"/>
                        <Label fx:id="errStatut" style="-fx-text-fill: #ef4444; -fx-font-size: 12; -fx-wrap-text: true;" visible="false"/>
                    </VBox>
                </GridPane>
            </VBox>

            <!-- Description Card -->
            <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 4);">
                <Label text="Description" style="-fx-font-size: 18; -fx-font-weight: 600; -fx-text-fill: #1e293b;"/>
                
                <VBox spacing="6">
                    <Label text="Description du produit *" style="-fx-font-weight: 500; -fx-text-fill: #374151;"/>
                    <TextArea fx:id="fieldDescription" prefHeight="120" style="-fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-padding: 16; -fx-font-size: 14; -fx-wrap-text: true;"/>
                    <Label fx:id="errDescription" style="-fx-text-fill: #ef4444; -fx-font-size: 12; -fx-wrap-text: true;" visible="false"/>
                </VBox>
            </VBox>

            <!-- Image Card -->
            <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 4);">
                <Label text="Image du Produit" style="-fx-font-size: 18; -fx-font-weight: 600; -fx-text-fill: #1e293b;"/>
                
                <VBox spacing="12">
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <TextField fx:id="fieldImage" promptText="URL de l'image..." HBox.hgrow="ALWAYS" style="-fx-pref-height: 48; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-padding: 0 16; -fx-font-size: 14;"/>
                        <Button text="Parcourir" onAction="#browseImage" style="-fx-background-color: #4f46e5; -fx-text-fill: white; -fx-background-radius: 12; -fx-pref-height: 48; -fx-pref-width: 120; -fx-font-weight: 600; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- Validation Summary -->
            <VBox fx:id="validationCard" visible="false" style="-fx-background-color: #fef2f2; -fx-background-radius: 12; -fx-padding: 16; -fx-border-color: #fecaca; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(239, 68, 68, 0.1), 5, 0, 0, 2);">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="!" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 50%; -fx-pref-width: 20; -fx-pref-height: 20; -fx-alignment: center; -fx-font-weight: bold;"/>
                    <Label fx:id="validationSummary" style="-fx-font-size: 14; -fx-font-weight: 600; -fx-text-fill: #dc2626;"/>
                </HBox>
            </VBox>

            <!-- Action Buttons -->
            <HBox spacing="16" alignment="CENTER_RIGHT">
                <Button text="Annuler" onAction="#goBack" style="-fx-background-color: white; -fx-text-fill: #6b7280; -fx-background-radius: 12; -fx-pref-height: 48; -fx-pref-width: 120; -fx-font-weight: 600; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-cursor: hand;"/>
                <Button fx:id="btnSave" text="Enregistrer le Produit" onAction="#saveProduit" style="-fx-background-color: linear-gradient(to right, #4f46e5, #7c3aed); -fx-text-fill: white; -fx-background-radius: 12; -fx-pref-height: 48; -fx-pref-width: 180; -fx-font-weight: 600; -fx-cursor: hand;"/>
            </HBox>

        </VBox>
    </ScrollPane>

</VBox>
