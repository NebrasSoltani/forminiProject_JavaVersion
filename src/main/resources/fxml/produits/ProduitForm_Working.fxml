<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.formini.controllers.produits.ProduitFormController"
      spacing="20" styleClass="content-area"
      style="-fx-background-color: #f8f9fa; -fx-padding: 20;">
    
    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 0 0 20 0;">
        <Button text="←" onAction="#goBack" style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-background-radius: 5; -fx-pref-width: 35; -fx-pref-height: 35; -fx-font-weight: bold;"/>
        <VBox spacing="3">
            <Label fx:id="labelFormTitle" text="Ajouter un Produit" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
            <Label text="Remplissez les informations du produit" style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
        </VBox>
    </HBox>

    <!-- Form Content -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
        <VBox spacing="20">
            
            <!-- Basic Info Section -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                <Label text="Informations de base" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                
                <GridPane hgap="15" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
                    </columnConstraints>
                    
                    <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="Nom du produit" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #4a5568;"/>
                        <TextField fx:id="fieldNom" promptText="Ex: MacBook Pro 14\"" prefHeight="40" style="-fx-border-color: #e2e8f0; -fx-border-radius: 5;"/>
                        <Label fx:id="errNom" style="-fx-text-fill: #e53e3e; -fx-font-size: 11px;" visible="false"/>
                    </VBox>

                    <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="Catégorie" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #4a5568;"/>
                        <ComboBox fx:id="fieldCategorie" promptText="Sélectionnez une catégorie" prefHeight="40" style="-fx-border-color: #e2e8f0; -fx-border-radius: 5;"/>
                        <Label fx:id="errCategorie" style="-fx-text-fill: #e53e3e; -fx-font-size: 11px;" visible="false"/>
                    </VBox>

                    <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                        <Label text="Description" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #4a5568;"/>
                        <TextArea fx:id="fieldDescription" prefHeight="80" promptText="Décrivez le produit..." wrapText="true" style="-fx-border-color: #e2e8f0; -fx-border-radius: 5;"/>
                        <Label fx:id="errDescription" style="-fx-text-fill: #e53e3e; -fx-font-size: 11px;" visible="false"/>
                    </VBox>
                </GridPane>
            </VBox>

            <!-- Pricing Section -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                <Label text="Prix et Stock" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                
                <GridPane hgap="15" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
                    </columnConstraints>
                    
                    <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="Prix unitaire (DT)" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #4a5568;"/>
                        <TextField fx:id="fieldPrix" promptText="0.000" prefHeight="40" style="-fx-border-color: #e2e8f0; -fx-border-radius: 5;"/>
                        <Label fx:id="errPrix" style="-fx-text-fill: #e53e3e; -fx-font-size: 11px;" visible="false"/>
                    </VBox>

                    <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="Quantité en stock" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #4a5568;"/>
                        <TextField fx:id="fieldStock" promptText="0" prefHeight="40" style="-fx-border-color: #e2e8f0; -fx-border-radius: 5;"/>
                        <Label fx:id="errStock" style="-fx-text-fill: #e53e3e; -fx-font-size: 11px;" visible="false"/>
                    </VBox>
                </GridPane>
            </VBox>

            <!-- Status Section -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                <Label text="Statut et Date" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                
                <GridPane hgap="15" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
                    </columnConstraints>
                    
                    <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="Date de création" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #4a5568;"/>
                        <DatePicker fx:id="fieldDateCreation" prefHeight="40" style="-fx-border-color: #e2e8f0; -fx-border-radius: 5;"/>
                        <Label fx:id="errDateCreation" style="-fx-text-fill: #e53e3e; -fx-font-size: 11px;" visible="false"/>
                    </VBox>

                    <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="Statut" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #4a5568;"/>
                        <ComboBox fx:id="fieldStatut" promptText="Sélectionnez le statut" prefHeight="40" style="-fx-border-color: #e2e8f0; -fx-border-radius: 5;"/>
                        <Label fx:id="errStatut" style="-fx-text-fill: #e53e3e; -fx-font-size: 11px;" visible="false"/>
                    </VBox>
                </GridPane>
            </VBox>

            <!-- Image Section -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                <Label text="Image du produit" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                
                <VBox spacing="5">
                    <Label text="URL de l'image" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #4a5568;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="fieldImage" promptText="https://example.com/image.jpg" HBox.hgrow="ALWAYS" prefHeight="40" style="-fx-border-color: #e2e8f0; -fx-border-radius: 5;"/>
                        <Button text="📁" onAction="#browseImage" style="-fx-background-color: #9f7aea; -fx-text-fill: white; -fx-background-radius: 5; -fx-pref-width: 40; -fx-pref-height: 40;"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- Validation Summary -->
            <VBox fx:id="validationCard" spacing="10" style="-fx-background-color: #fed7d7; -fx-background-radius: 8; -fx-padding: 15; -fx-border-color: #fc8181; -fx-border-width: 1;" visible="false">
                <Label text="Veuillez corriger les erreurs suivantes:" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #c53030;"/>
                <Label fx:id="validationSummary" style="-fx-font-size: 12px; -fx-text-fill: #742a2a; -fx-wrap-text: true;"/>
            </VBox>

        </VBox>
    </ScrollPane>

    <!-- Action Buttons -->
    <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 20 0 0 0;">
        <Button text="Annuler" onAction="#goBack" style="-fx-background-color: white; -fx-text-fill: #667eea; -fx-border-color: #667eea; -fx-border-width: 2; -fx-background-radius: 20; -fx-padding: 10 25; -fx-font-size: 14px; -fx-font-weight: 600;"/>
        <Button fx:id="btnSave" text="💾 Enregistrer le produit" onAction="#saveProduit" style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-border-color: transparent; -fx-background-radius: 20; -fx-padding: 10 30; -fx-font-size: 14px; -fx-font-weight: 600;"/>
    </HBox>

</VBox>
