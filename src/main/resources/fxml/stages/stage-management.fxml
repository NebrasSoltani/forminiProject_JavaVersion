<AnchorPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.formini.controllers.stages.StageManagementController">
   <children>
      <TabPane fx:id="tabPane" layoutX="14.0" layoutY="14.0" prefHeight="672.0" prefWidth="972.0" tabClosingPolicy="UNAVAILABLE" AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="14.0">
        <tabs>
          <Tab text="Offres de Stage">
            <content>
              <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                     <children>
                        <VBox spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                           <children>
                              <HBox spacing="10.0" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Gestion des Offres de Stage">
                                       <font>
                                          <Font name="System Bold" size="24.0" />
                                       </font>
                                    </Label>
                                    <Region HBox.hgrow="ALWAYS" />
                                    <TextField fx:id="txtRechercheOffre" prefWidth="250.0" promptText="Rechercher par titre, entreprise..." />
                                 </children>
                              </HBox>
                              <HBox prefHeight="350.0" prefWidth="952.0" spacing="15.0">
                                 <children>
                                    <VBox prefHeight="350.0" prefWidth="400.0" spacing="10.0" style="-fx-border-color: #cccccc; -fx-padding: 10;">
                                       <children>
                                          <GridPane vgap="5.0">
                                            <columnConstraints>
                                              <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                              <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
                                            </columnConstraints>
                                            <rowConstraints>
                                              <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                              <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                              <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                                <RowConstraints minHeight="10.0" prefHeight="60.0" vgrow="SOMETIMES" />
                                            </rowConstraints>
                                             <children>
                                                <Label text="Titre:" />
                                                <TextField fx:id="txtTitreOffre" GridPane.columnIndex="1" />
                                                <Label text="Entreprise:" GridPane.rowIndex="1" />
                                                <TextField fx:id="txtEntrepriseOffre" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                                <Label text="Lieu:" GridPane.rowIndex="2" />
                                                <TextField fx:id="txtLieuOffre" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                                <Label text="Domaine:" GridPane.rowIndex="3" />
                                                <TextField fx:id="txtDomaineOffre" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                                <Label text="Statut:" GridPane.rowIndex="4" />
                                                <ComboBox fx:id="comboStatutOffre" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                                                <Label text="Description:" GridPane.rowIndex="5" />
                                                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="5">
                                                   <children>
                                                      <TextArea fx:id="txtDescriptionOffre" prefHeight="100.0" prefWidth="200.0" wrapText="true" />
                                                      <Button mnemonicParsing="false" onAction="#handleGenererDescriptionIA" text="✨ GÉNÉRER AVEC L'IA" style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-size: 10px;" maxWidth="Infinity" />
                                                   </children>
                                                </VBox>
                                             </children>
                                          </GridPane>
                                          <HBox alignment="CENTER" spacing="10.0">
                                             <children>
                                                <Button mnemonicParsing="false" onAction="#handleAjouterOffre" text="Ajouter" />
                                                <Button mnemonicParsing="false" onAction="#handleModifierOffre" text="Modifier" />
                                                <Button mnemonicParsing="false" onAction="#handleSupprimerOffre" text="Supprimer" />
                                                <Button mnemonicParsing="false" onAction="#handleViderOffre" text="Vider" />
                                             </children>
                                             <padding>
                                                <Insets top="10.0" />
                                             </padding>
                                          </HBox>
                                       </children>
                                    </VBox>
                                    <TableView fx:id="tableOffres" prefHeight="350.0" prefWidth="550.0">
                                      <columns>
                                        <TableColumn fx:id="colIdOffre" prefWidth="40.0" text="ID" />
                                        <TableColumn fx:id="colTitreOffre" prefWidth="120.0" text="Titre" />
                                          <TableColumn fx:id="colEntrepriseOffre" prefWidth="100.0" text="Entreprise" />
                                          <TableColumn fx:id="colDomaineOffre" prefWidth="100.0" text="Domaine" />
                                          <TableColumn fx:id="colStatutOffre" prefWidth="80.0" text="Statut" />
                                      </columns>
                                    </TableView>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </AnchorPane>
            </content>
          </Tab>
          <Tab text="Candidatures">
            <content>
              <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                     <children>
                        <VBox spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                           <children>
                              <Label text="Gestion des Candidatures">
                                 <font>
                                    <Font name="System Bold" size="24.0" />
                                 </font>
                              </Label>
                              <HBox prefHeight="350.0" prefWidth="952.0" spacing="15.0">
                                 <children>
                                    <VBox prefHeight="350.0" prefWidth="400.0" spacing="10.0" style="-fx-border-color: #cccccc; -fx-padding: 10;">
                                       <children>
                                          <GridPane vgap="5.0">
                                             <columnConstraints>
                                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
                                             </columnConstraints>
                                             <rowConstraints>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                                <RowConstraints minHeight="10.0" prefHeight="60.0" vgrow="SOMETIMES" />
                                             </rowConstraints>
                                             <children>
                                                <Label text="Offre ID:" />
                                                <TextField fx:id="txtOffreIdCand" GridPane.columnIndex="1" />
                                                <Label text="Apprenant ID:" GridPane.rowIndex="1" />
                                                <TextField fx:id="txtApprenantIdCand" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                                <Label text="Statut:" GridPane.rowIndex="2" />
                                                <ComboBox fx:id="comboStatutCand" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                                <Label text="Lettre Motivation:" GridPane.rowIndex="3" />
                                                <TextArea fx:id="txtLettreCand" prefHeight="60.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                                <Label text="Commentaire:" GridPane.rowIndex="4" />
                                                <TextArea fx:id="txtCommentaireCand" prefHeight="60.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                                             </children>
                                             <rowConstraints>
                                                <RowConstraints />
                                                <RowConstraints />
                                                <RowConstraints />
                                                <RowConstraints minHeight="10.0" prefHeight="60.0" />
                                                <RowConstraints minHeight="10.0" prefHeight="60.0" />
                                             </rowConstraints>
                                          </GridPane>
                                          <HBox alignment="CENTER" spacing="10.0">
                                             <children>
                                                <Button mnemonicParsing="false" onAction="#handleModifierCand" text="Enregistrer" style="-fx-background-color: #3498db; -fx-text-fill: white;" />
                                                <Button mnemonicParsing="false" onAction="#handleAnalyseIA" text="✨ ANALYSE IA" style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-weight: bold;" />
                                                <Button mnemonicParsing="false" onAction="#handleAccepterCand" text="ACCEPTER" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;" />
                                                <Button mnemonicParsing="false" onAction="#handleRefuserCand" text="REFUSER" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" />
                                                <Button mnemonicParsing="false" onAction="#handleSupprimerCand" text="Supprimer" />
                                             </children>
                                             <padding>
                                                <Insets top="10.0" />
                                             </padding>
                                          </HBox>
                                       </children>
                                    </VBox>
                                    <TableView fx:id="tableCandidatures" prefHeight="350.0" prefWidth="550.0">
                                       <columns>
                                          <TableColumn fx:id="colIdCand" prefWidth="40.0" text="ID" />
                                          <TableColumn fx:id="colOffreCand" prefWidth="120.0" text="Offre" />
                                          <TableColumn fx:id="colApprenantCand" prefWidth="120.0" text="Apprenant" />
                                          <TableColumn fx:id="colStatutCand" prefWidth="100.0" text="Statut" />
                                       </columns>
                                    </TableView>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </AnchorPane>
            </content>
