<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.formini.controllers.MainController"
            prefWidth="1200" prefHeight="750"
            stylesheets="@/css/style.css">

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  SIDEBAR                                               -->
    <!-- ══════════════════════════════════════════════════════ -->
    <!-- ══════════════════════════════════════════════════════ -->
    <!--  SIDEBAR (ADMIN PANEL)                                 -->
    <!-- ══════════════════════════════════════════════════════ -->
    <left>
        <VBox fx:id="sidebar" styleClass="sidebar" prefWidth="260" spacing="0">

            <!-- Premium Logo Section -->
            <VBox styleClass="sidebar-logo" alignment="CENTER" spacing="12">
                <HBox alignment="CENTER" spacing="12">
                    <StackPane styleClass="logo-icon-bg">
                        <Label text="F" styleClass="logo-icon-text"/>
                    </StackPane>
                    <VBox spacing="-2">
                        <Label text="Formini.tn" styleClass="logo-text-bold" style="-fx-font-size: 20px;"/>
                        <Label text="ADMINISTRATION" style="-fx-font-size: 10px; -fx-text-fill: -fx-warning; -fx-font-weight: bold; -fx-letter-spacing: 1px;"/>
                    </VBox>
                </HBox>
            </VBox>

            <Separator styleClass="sidebar-sep"/>

            <!-- Navigation Menu -->
            <VBox spacing="5" style="-fx-padding: 25 15;" VBox.vgrow="ALWAYS">
                <Label text="GESTION DU CONTENU" style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-font-weight: bold; -fx-padding: 0 0 10 10;"/>
                
                <Button fx:id="btnDashboard" text="🏠  Tableau de bord" onAction="#showDashboard" styleClass="nav-sub" maxWidth="Infinity"/>
                <Button fx:id="btnBlogList" text="📝  Gestion des Blogs" onAction="#showBlogList" styleClass="nav-sub" maxWidth="Infinity"/>
                <Button fx:id="btnEventList" text="📅  Gestion des Événements" onAction="#showEventList" styleClass="nav-sub" maxWidth="Infinity"/>
                
                <Region prefHeight="30"/>
                <Label text="ACTIONS RAPIDES" style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-font-weight: bold; -fx-padding: 0 0 10 10;"/>
                <Button fx:id="btnBlogAdd" text="➕  Nouveau Blog" onAction="#showBlogAdd" styleClass="nav-sub" maxWidth="Infinity"/>
                <Button fx:id="btnEventAdd" text="➕  Nouvel Événement" onAction="#showEventAdd" styleClass="nav-sub" maxWidth="Infinity"/>
            </VBox>

            <!-- Bottom Navigation Actions -->
            <VBox spacing="15" style="-fx-padding: 20;">
                <Button text="←  Voir le Site Public" onAction="#switchToPublic" 
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: rgba(255,255,255,0.2); -fx-border-radius: 25; -fx-background-radius: 25; -fx-padding: 12 20; -fx-font-weight: bold; -fx-cursor: hand;" 
                        maxWidth="Infinity"/>
                <Button text="🚪 Déconnexion" style="-fx-background-color: rgba(255,255,255,0.05); -fx-text-fill: #94a3b8; -fx-background-radius: 10; -fx-padding: 10; -fx-cursor: hand;" maxWidth="Infinity"/>
            </VBox>

            <Separator styleClass="sidebar-sep"/>
            
            <!-- User Info -->
            <HBox styleClass="sidebar-user" alignment="CENTER_LEFT" spacing="12">
                <Circle fx:id="userAvatar" radius="22" styleClass="user-avatar" style="-fx-fill: -fx-primary;"/>
                <VBox spacing="2">
                    <Label fx:id="labelUserName" text="Duaa Duaa" styleClass="user-name" style="-fx-font-size: 14px;"/>
                    <Label fx:id="labelUserRole" text="Administrateur" styleClass="user-role" style="-fx-font-size: 11px;"/>
                </VBox>
            </HBox>
        </VBox>
    </left>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  MAIN CONTENT AREA                                     -->
    <!-- ══════════════════════════════════════════════════════ -->
    <center>
        <VBox>
            <!-- Top Bar -->
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
                <Label fx:id="labelPageTitle" text="Tableau de bord" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="labelDate" styleClass="topbar-date"/>
                <Button text="🔔" styleClass="icon-btn"/>
                <Button text="⚙" styleClass="icon-btn" onAction="#openSettings"/>
            </HBox>

            <!-- Dynamic Content (swapped by controllers) -->
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" styleClass="content-area"/>
        </VBox>
    </center>

</BorderPane>
