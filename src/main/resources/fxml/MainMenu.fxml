<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.formini.controllers.MainController"
            prefWidth="1200" prefHeight="750"
            stylesheets="@/css/style.css">

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  SIDEBAR                                               -->
    <!-- ══════════════════════════════════════════════════════ -->
    <left>
        <VBox fx:id="sidebar" styleClass="sidebar" prefWidth="230" spacing="0">

            <!-- Logo Section -->
            <VBox styleClass="sidebar-logo" alignment="CENTER" spacing="8">
                <HBox alignment="CENTER" spacing="10">
                    <StackPane styleClass="logo-icon-bg">
                        <Label text="f" styleClass="logo-icon-text"/>
                    </StackPane>
                    <VBox spacing="-2">
                        <Label text="Formini.tn" styleClass="logo-text-bold"/>
                        <Label text="فروميني.تونس" styleClass="logo-arabic"/>
                    </VBox>
                </HBox>
            </VBox>

            <Separator styleClass="sidebar-sep"/>

            <!-- Navigation Menu -->
            <Accordion styleClass="nav-accordion" VBox.vgrow="ALWAYS">
                <panes>
                    <!-- Tableau de bord -->
                    <TitledPane fx:id="paneDashboard" animated="false" text="🏠  Tableau de bord">
                        <content>
                            <VBox spacing="2">
                                <Button fx:id="btnDashboard" text="📊  Vue d'ensemble" onAction="#showDashboard" styleClass="nav-sub" maxWidth="Infinity"/>
                            </VBox>
                        </content>
                    </TitledPane>

                    <!-- Blogs -->
                    <TitledPane fx:id="paneBlogs" animated="false" text="📝  Contenu">
                        <content>
                            <VBox spacing="2">
                                <Button fx:id="btnBlogList" text="📄  Liste des Blogs" onAction="#showBlogList" styleClass="nav-sub" maxWidth="Infinity"/>
                                <Button fx:id="btnBlogAdd" text="➕  Nouveau Blog" onAction="#showBlogAdd" styleClass="nav-sub" maxWidth="Infinity"/>
                            </VBox>
                        </content>
                    </TitledPane>

                    <!-- Événements -->
                    <TitledPane fx:id="paneEvents" animated="false" text="🎪  Événements">
                        <content>
                            <VBox spacing="2">
                                <Button fx:id="btnEventList" text="📅  Liste des Événements" onAction="#showEventList" styleClass="nav-sub" maxWidth="Infinity"/>
                                <Button fx:id="btnEventAdd" text="➕  Nouvel Événement" onAction="#showEventAdd" styleClass="nav-sub" maxWidth="Infinity"/>
                            </VBox>
                        </content>
                    </TitledPane>
            </panes>
            </Accordion>

            <VBox spacing="10" alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS" style="-fx-padding: 20;">
                <Button text="🌐 Voir le Site Public" onAction="#switchToPublic" styleClass="nav-btn-active" maxWidth="Infinity" style="-fx-background-color: #3b82f6;"/>
            </VBox>

            <!-- Bottom user info -->
            <Separator styleClass="sidebar-sep"/>
            <HBox styleClass="sidebar-user" alignment="CENTER_LEFT" spacing="10">
                <Circle fx:id="userAvatar" radius="20" styleClass="user-avatar"/>
                <VBox spacing="2">
                    <Label fx:id="labelUserName" text="DUAA Duaa" styleClass="user-name"/>
                    <Label fx:id="labelUserRole" text="Administrateur" styleClass="user-role"/>
                </VBox>
            </HBox>
        </VBox>
    </left>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  MAIN CONTENT AREA                                     -->
    <!-- ══════════════════════════════════════════════════════ -->
    <center>
        <VBox>
            <!-- Top Bar -->
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
                <Label fx:id="labelPageTitle" text="Tableau de bord" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="labelDate" styleClass="topbar-date"/>
                <Button text="🔔" styleClass="icon-btn"/>
                <Button text="⚙" styleClass="icon-btn" onAction="#openSettings"/>
            </HBox>

            <!-- Dynamic Content (swapped by controllers) -->
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" styleClass="content-area"/>
        </VBox>
    </center>

</BorderPane>
