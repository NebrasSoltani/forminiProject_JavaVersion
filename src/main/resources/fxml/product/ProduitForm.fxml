<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.formini.controllers.produit.ProduitFormController"
      spacing="20" styleClass="content-area"
      stylesheets="@/css/style.css"
      style="-fx-background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">

    <!-- Modern Header -->
    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 20 30 10 30;">
        <Button text=" " onAction="#goBack" styleClass="btn-back" style="-fx-background-color: white; -fx-text-fill: #667eea; -fx-border-color: transparent; -fx-background-radius: 50; -fx-pref-width: 40; -fx-pref-height: 40; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <VBox spacing="5">
            <Label fx:id="labelFormTitle" text="Ajouter un Produit" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Remplissez les informations ci-dessous pour ajouter un nouveau produit" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.8);"/>
        </VBox>
    </HBox>

    <!-- Main Content Container -->
    <ScrollPane fitToWidth="true" styleClass="modern-scroll-pane" VBox.vgrow="ALWAYS" style="-fx-background: transparent; -fx-border-color: transparent;">
        <VBox spacing="25" style="-fx-padding: 0 30 30 30;">
            
            <!-- Basic Information Card -->
            <VBox styleClass="modern-form-card" spacing="20" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 20, 0, 0, 10); -fx-padding: 25;">
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="" style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-background-radius: 50; -fx-pref-width: 35; -fx-pref-height: 35; -fx-alignment: center; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <VBox spacing="2">
                        <Label text="Informations de base" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                        <Label text="Nom, catégorie et description du produit" style="-fx-font-size: 13px; -fx-text-fill: #718096;"/>
                    </VBox>
                </HBox>
                
                <GridPane hgap="25" vgap="20">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="250" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="250" />
                    </columnConstraints>
                    
                    <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="Nom du produit" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4a5568;">
                            <graphic>
                                <Label text="" style="-fx-text-fill: #667eea; -fx-font-size: 12px;"/>
                            </graphic>
                        </Label>
                        <TextField fx:id="fieldNom" styleClass="modern-input" promptText="Ex: MacBook Pro 14\"" prefHeight="45"/>
                        <Label fx:id="errNom" styleClass="error-label" visible="false" style="-fx-font-size: 12px; -fx-text-fill: #e53e3e;"/>
                    </VBox>

                    <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="Catégorie" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4a5568;">
                            <graphic>
                                <Label text="" style="-fx-text-fill: #667eea; -fx-font-size: 12px;"/>
                            </graphic>
                        </Label>
                        <ComboBox fx:id="fieldCategorie" styleClass="modern-combo" maxWidth="Infinity" promptText="Sélectionnez une catégorie" prefHeight="45"/>
                        <Label fx:id="errCategorie" styleClass="error-label" visible="false" style="-fx-font-size: 12px; -fx-text-fill: #e53e3e;"/>
                    </VBox>

                    <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                        <Label text="Description" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4a5568;">
                            <graphic>
                                <Label text="" style="-fx-text-fill: #667eea; -fx-font-size: 12px;"/>
                            </graphic>
                        </Label>
                        <TextArea fx:id="fieldDescription" styleClass="modern-textarea" prefHeight="100" promptText="Décrivez les caractéristiques, avantages et utilisation du produit..." wrapText="true"/>
                        <Label fx:id="errDescription" styleClass="error-label" visible="false" style="-fx-font-size: 12px; -fx-text-fill: #e53e3e;"/>
                    </VBox>
                </GridPane>
            </VBox>

            <!-- Pricing & Inventory Card -->
            <VBox styleClass="modern-form-card" spacing="20" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 20, 0, 0, 10); -fx-padding: 25;">
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="" style="-fx-background-color: #48bb78; -fx-text-fill: white; -fx-background-radius: 50; -fx-pref-width: 35; -fx-pref-height: 35; -fx-alignment: center; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <VBox spacing="2">
                        <Label text="Prix et Stock" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                        <Label text="Tarification et gestion des stocks" style="-fx-font-size: 13px; -fx-text-fill: #718096;"/>
                    </VBox>
                </HBox>
                
                <GridPane hgap="25" vgap="20">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="250" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="250" />
                    </columnConstraints>
                    
                    <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="Prix unitaire (DT)" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4a5568;">
                            <graphic>
                                <Label text="" style="-fx-text-fill: #48bb78; -fx-font-size: 12px;"/>
                            </graphic>
                        </Label>
                        <TextField fx:id="fieldPrix" styleClass="modern-input" promptText="0.000" prefHeight="45"/>
                        <Label fx:id="errPrix" styleClass="error-label" visible="false" style="-fx-font-size: 12px; -fx-text-fill: #e53e3e;"/>
                    </VBox>

                    <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="Quantité en stock" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4a5568;">
                            <graphic>
                                <Label text="" style="-fx-text-fill: #48bb78; -fx-font-size: 12px;"/>
                            </graphic>
                        </Label>
                        <TextField fx:id="fieldStock" styleClass="modern-input" promptText="0" prefHeight="45"/>
                        <Label fx:id="errStock" styleClass="error-label" visible="false" style="-fx-font-size: 12px; -fx-text-fill: #e53e3e;"/>
                    </VBox>
                </GridPane>
            </VBox>

            <!-- Status & Date Card -->
            <VBox styleClass="modern-form-card" spacing="20" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 20, 0, 0, 10); -fx-padding: 25;">
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="" style="-fx-background-color: #ed8936; -fx-text-fill: white; -fx-background-radius: 50; -fx-pref-width: 35; -fx-pref-height: 35; -fx-alignment: center; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <VBox spacing="2">
                        <Label text="Statut et Date" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                        <Label text="Disponibilité et date de création" style="-fx-font-size: 13px; -fx-text-fill: #718096;"/>
                    </VBox>
                </HBox>
                
                <GridPane hgap="25" vgap="20">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="250" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="250" />
                    </columnConstraints>
                    
                    <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="Date de création" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4a5568;">
                            <graphic>
                                <Label text="" style="-fx-text-fill: #ed8936; -fx-font-size: 12px;"/>
                            </graphic>
                        </Label>
                        <DatePicker fx:id="fieldDateCreation" styleClass="modern-date-picker" maxWidth="Infinity" prefHeight="45"/>
                        <Label fx:id="errDateCreation" styleClass="error-label" visible="false" style="-fx-font-size: 12px; -fx-text-fill: #e53e3e;"/>
                    </VBox>

                    <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="Statut" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4a5568;">
                            <graphic>
                                <Label text="" style="-fx-text-fill: #ed8936; -fx-font-size: 12px;"/>
                            </graphic>
                        </Label>
                        <ComboBox fx:id="fieldStatut" styleClass="modern-combo" maxWidth="Infinity" promptText="Sélectionnez le statut" prefHeight="45"/>
                        <Label fx:id="errStatut" styleClass="error-label" visible="false" style="-fx-font-size: 12px; -fx-text-fill: #e53e3e;"/>
                    </VBox>
                </GridPane>
            </VBox>

            <!-- Media Card -->
            <VBox styleClass="modern-form-card" spacing="20" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 20, 0, 0, 10); -fx-padding: 25;">
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="" style="-fx-background-color: #9f7aea; -fx-text-fill: white; -fx-background-radius: 50; -fx-pref-width: 35; -fx-pref-height: 35; -fx-alignment: center; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <VBox spacing="2">
                        <Label text="Image du produit" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d3748;"/>
                        <Label text="URL ou sélection de fichier local" style="-fx-font-size: 13px; -fx-text-fill: #718096;"/>
                    </VBox>
                </HBox>
                
                <VBox spacing="8">
                    <Label text="URL de l'image" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4a5568;">
                        <graphic>
                            <Label text="" style="-fx-text-fill: #9f7aea; -fx-font-size: 12px;"/>
                        </graphic>
                    </Label>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <TextField fx:id="fieldImage" styleClass="modern-input" promptText="https://example.com/image.jpg" HBox.hgrow="ALWAYS" prefHeight="45"/>
                        <Button text=" " onAction="#browseImage" styleClass="btn-browse" style="-fx-background-color: #9f7aea; -fx-text-fill: white; -fx-border-color: transparent; -fx-background-radius: 8; -fx-pref-width: 45; -fx-pref-height: 45; -fx-font-size: 18px; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- Validation Summary -->
            <VBox fx:id="validationCard" styleClass="modern-form-card" spacing="15" style="-fx-background-color: #fed7d7; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(229,62,62,0.2), 15, 0, 0, 5); -fx-padding: 20; -fx-border-color: #fc8181; -fx-border-width: 1; -fx-border-radius: 15;" visible="false">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="" style="-fx-text-fill: #e53e3e; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Label text="Veuillez corriger les erreurs suivantes:" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #c53030;"/>
                </HBox>
                <Label fx:id="validationSummary" style="-fx-font-size: 13px; -fx-text-fill: #742a2a; -fx-wrap-text: true;"/>
            </VBox>

        </VBox>
    </ScrollPane>

    <!-- Modern Action Buttons -->
    <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 0 30 20 30;">
        <Button text="Annuler" onAction="#goBack" styleClass="btn-cancel" style="-fx-background-color: white; -fx-text-fill: #667eea; -fx-border-color: #667eea; -fx-border-width: 2; -fx-background-radius: 25; -fx-padding: 12 30; -fx-font-size: 14px; -fx-font-weight: 600; -fx-cursor: hand;"/>
        <Button fx:id="btnSave" text=" Enregistrer le produit" onAction="#saveProduit" styleClass="btn-save" style="-fx-background-color: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -fx-text-fill: white; -fx-border-color: transparent; -fx-background-radius: 25; -fx-padding: 12 35; -fx-font-size: 14px; -fx-font-weight: 600; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(102,126,234,0.3), 10, 0, 0, 0);"/>
    </HBox>

</VBox>
