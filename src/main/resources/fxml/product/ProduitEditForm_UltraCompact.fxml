<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.formini.controllers.produit.ProduitEditFormController"
      spacing="8" styleClass="content-area"
      stylesheets="/css/ultra-compact-forms.css">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="8" styleClass="form-header">
        <Button text="×" onAction="#close" styleClass="icon-btn-small"/>
        <Label fx:id="labelFormTitle" text="Modifier Produit" styleClass="form-title"/>
    </HBox>

    <!-- Form Content -->
    <VBox styleClass="compact-form-container" VBox.vgrow="ALWAYS" alignment="TOP_CENTER">
        <ScrollPane fitToWidth="true" styleClass="compact-scroll-pane" hbarPolicy="NEVER">
            <VBox spacing="6" styleClass="form-content">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

                <!-- Basic Info Section -->
                <TitledPane text="Informations" expanded="true" styleClass="form-section">
                    <GridPane hgap="10" vgap="8">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" minWidth="150" />
                            <ColumnConstraints hgrow="ALWAYS" minWidth="150" />
                        </columnConstraints>

                        <!-- Product ID & Name -->
                        <VBox styleClass="compact-form-group" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="ID" styleClass="compact-label"/>
                            <TextField fx:id="fieldId" styleClass="compact-control" editable="false" style="-fx-opacity: 0.6;"/>
                        </VBox>

                        <VBox styleClass="compact-form-group" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Nom *" styleClass="compact-label"/>
                            <TextField fx:id="fieldNom" styleClass="compact-control" promptText="Nom"/>
                            <Label fx:id="errNom" styleClass="error-label-small" visible="false"/>
                        </VBox>

                        <!-- Category & Status -->
                        <VBox styleClass="compact-form-group" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Catégorie *" styleClass="compact-label"/>
                            <ComboBox fx:id="fieldCategorie" styleClass="compact-control" maxWidth="Infinity" promptText="Catégorie"/>
                            <Label fx:id="errCategorie" styleClass="error-label-small" visible="false"/>
                        </VBox>

                        <VBox styleClass="compact-form-group" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Statut *" styleClass="compact-label"/>
                            <ComboBox fx:id="fieldStatut" styleClass="compact-control" maxWidth="Infinity" promptText="Statut"/>
                            <Label fx:id="errStatut" styleClass="error-label-small" visible="false"/>
                        </VBox>
                    </GridPane>
                </TitledPane>

                <!-- Details Section -->
                <TitledPane text="Détails" expanded="true" styleClass="form-section">
                    <VBox spacing="6">
                        <VBox styleClass="compact-form-group">
                            <Label text="Description *" styleClass="compact-label"/>
                            <TextArea fx:id="fieldDescription" styleClass="compact-control" prefHeight="60" promptText="Description..." wrapText="true"/>
                            <Label fx:id="errDescription" styleClass="error-label-small" visible="false"/>
                        </VBox>
                    </VBox>
                </TitledPane>

                <!-- Pricing & Stock Section -->
                <TitledPane text="Prix & Stock" expanded="true" styleClass="form-section">
                    <GridPane hgap="10" vgap="8">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" minWidth="150" />
                            <ColumnConstraints hgrow="ALWAYS" minWidth="150" />
                        </columnConstraints>

                        <VBox styleClass="compact-form-group" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Prix (DT) *" styleClass="compact-label"/>
                            <TextField fx:id="fieldPrix" styleClass="compact-control" promptText="0.000"/>
                            <Label fx:id="errPrix" styleClass="error-label-small" visible="false"/>
                        </VBox>

                        <VBox styleClass="compact-form-group" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Stock *" styleClass="compact-label"/>
                            <TextField fx:id="fieldStock" styleClass="compact-control" promptText="0"/>
                            <Label fx:id="errStock" styleClass="error-label-small" visible="false"/>
                        </VBox>
                    </GridPane>
                </TitledPane>

                <!-- Advanced Section (Collapsed by default) -->
                <TitledPane text="Avancé" expanded="false" styleClass="form-section">
                    <VBox spacing="6">
                        <VBox styleClass="compact-form-group">
                            <Label text="Image URL" styleClass="compact-label"/>
                            <HBox spacing="6" alignment="CENTER_LEFT">
                                <TextField fx:id="fieldImage" styleClass="compact-control" promptText="URL..." HBox.hgrow="ALWAYS"/>
                                <Button text="Aperçu" onAction="#previewImage" styleClass="btn-secondary-small"/>
                            </HBox>
                        </VBox>

                        <VBox styleClass="compact-form-group">
                            <Label text="Date création" styleClass="compact-label"/>
                            <DatePicker fx:id="fieldDateCreation" styleClass="compact-control" maxWidth="Infinity" editable="false" style="-fx-opacity: 0.6;"/>
                        </VBox>
                    </VBox>
                </TitledPane>

                <!-- Validation Summary -->
                <VBox styleClass="validation-container">
                    <Label fx:id="validationSummary" styleClass="error-label-small" visible="false" wrapText="true"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>

    <!-- Action Buttons -->
    <HBox spacing="8" alignment="CENTER_RIGHT" styleClass="form-actions">
        <Button text="Réinit." onAction="#resetForm" styleClass="btn-secondary-small"/>
        <Button text="Dupliquer" onAction="#duplicateProduct" styleClass="btn-info-small"/>
        <Button text="Supprimer" onAction="#deleteProduct" styleClass="btn-danger-small"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnSave" text="Mettre à jour" onAction="#updateProduit" styleClass="btn-primary-small"/>
    </HBox>

</VBox>
