<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.formini.controllers.produit.ProduitEditFormController"
      spacing="20"
      prefWidth="900" prefHeight="650"
      maxWidth="Infinity" maxHeight="Infinity">

    <!-- Enhanced Header -->
    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="form-header" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0; -fx-padding: 15 20 15 20;">
        <Button text="×" onAction="#close" styleClass="icon-btn-small" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 50%; -fx-pref-width: 35; -fx-pref-height: 35;"/>
        <Label fx:id="labelFormTitle" text="Modifier un Produit" styleClass="form-title" style="-fx-font-size: 20px; -fx-font-weight: 600; -fx-text-fill: #1e293b;"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Form Content -->
    <VBox styleClass="compact-form-container" VBox.vgrow="ALWAYS" alignment="TOP_CENTER">
        <ScrollPane fitToWidth="true" styleClass="compact-scroll-pane" hbarPolicy="NEVER">
            <VBox spacing="12" styleClass="form-content">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <!-- Basic Info Section -->
                <TitledPane text="Informations de base" expanded="true" styleClass="form-section">
                    <GridPane hgap="15" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
                            <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
                        </columnConstraints>

                        <!-- Product ID -->
                        <VBox styleClass="compact-form-group" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="ID" styleClass="compact-label"/>
                            <TextField fx:id="fieldId" styleClass="compact-control" editable="false" style="-fx-opacity: 0.6;"/>
                        </VBox>

                        <!-- Product Name -->
                        <VBox styleClass="compact-form-group" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Nom *" styleClass="compact-label"/>
                            <TextField fx:id="fieldNom" styleClass="compact-control" promptText="Nom du produit"/>
                            <Label fx:id="errNom" styleClass="error-label-small" visible="false"/>
                        </VBox>

                        <!-- Category -->
                        <VBox styleClass="compact-form-group" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Catégorie *" styleClass="compact-label"/>
                            <ComboBox fx:id="fieldCategorie" styleClass="compact-control" maxWidth="Infinity" promptText="Catégorie"/>
                            <Label fx:id="errCategorie" styleClass="error-label-small" visible="false"/>
                        </VBox>

                        <!-- Status -->
                        <VBox styleClass="compact-form-group" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Statut *" styleClass="compact-label"/>
                            <ComboBox fx:id="fieldStatut" styleClass="compact-control" maxWidth="Infinity" promptText="Statut"/>
                            <Label fx:id="errStatut" styleClass="error-label-small" visible="false"/>
                        </VBox>
                    </GridPane>
                </TitledPane>

                <!-- Details Section -->
                <TitledPane text="Détails du produit" expanded="true" styleClass="form-section">
                    <VBox spacing="12">
                        <!-- Description -->
                        <VBox styleClass="compact-form-group">
                            <Label text="Description *" styleClass="compact-label"/>
                            <TextArea fx:id="fieldDescription" styleClass="compact-control" prefHeight="80" promptText="Description du produit..." wrapText="true"/>
                            <Label fx:id="errDescription" styleClass="error-label-small" visible="false"/>
                        </VBox>
                    </VBox>
                </TitledPane>

                <!-- Pricing & Stock Section -->
                <TitledPane text="Prix et Stock" expanded="true" styleClass="form-section">
                    <GridPane hgap="15" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
                            <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
                        </columnConstraints>

                        <!-- Price -->
                        <VBox styleClass="compact-form-group" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Prix (DT) *" styleClass="compact-label"/>
                            <TextField fx:id="fieldPrix" styleClass="compact-control" promptText="0.000"/>
                            <Label fx:id="errPrix" styleClass="error-label-small" visible="false"/>
                        </VBox>

                        <!-- Stock -->
                        <VBox styleClass="compact-form-group" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Stock *" styleClass="compact-label"/>
                            <TextField fx:id="fieldStock" styleClass="compact-control" promptText="0"/>
                            <Label fx:id="errStock" styleClass="error-label-small" visible="false"/>
                        </VBox>
                    </GridPane>
                </TitledPane>

                <!-- Enhanced Media Section -->
                <TitledPane text="Média" expanded="true" styleClass="form-section">
                    <VBox spacing="15" styleClass="compact-form-group">
                        <!-- Image Preview -->
                        <VBox spacing="10" alignment="CENTER" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 15;">
                            <Label text="Aperçu de l'image" styleClass="compact-label" style="-fx-font-weight: 600;"/>
                            <ImageView fx:id="imagePreview" fitWidth="200" fitHeight="150" preserveRatio="true" style="-fx-background-color: #f1f5f9; -fx-border-color: #d1d5db; -fx-border-radius: 6;"/>
                        </VBox>
                        
                        <!-- Image URL Input -->
                        <VBox spacing="8">
                            <Label text="URL de l'image" styleClass="compact-label"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <TextField fx:id="fieldImage" styleClass="compact-control" promptText="URL de l'image..." HBox.hgrow="ALWAYS"/>
                                <Button text="Aperçu" onAction="#updateInlinePreview" styleClass="icon-btn-small" style="-fx-background-color: #3b82f6; -fx-text-fill: white;"/>
                            </HBox>
                        </VBox>
                        
                        <!-- Image Selection Buttons -->
                        <VBox spacing="8">
                            <Label text="Options d'image" styleClass="compact-label" style="-fx-font-weight: 600;"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Button text="Choisir un fichier" onAction="#browseImage" styleClass="btn-secondary-small" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: 500;"/>
                                <Button text="Effacer l'image" onAction="#clearImage" styleClass="btn-secondary-small" style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: 500;"/>
                                <Button text="Image par défaut" onAction="#setDefaultImage" styleClass="btn-secondary-small" style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-font-weight: 500;"/>
                            </HBox>
                        </VBox>
                    </VBox>
                </TitledPane>

                <!-- Creation Date (Read-only) -->
                <TitledPane text="Informations système" expanded="false" styleClass="form-section">
                    <VBox styleClass="compact-form-group">
                        <Label text="Date de création" styleClass="compact-label"/>
                        <DatePicker fx:id="fieldDateCreation" styleClass="compact-control" maxWidth="Infinity" editable="false" style="-fx-opacity: 0.6;"/>
                    </VBox>
                </TitledPane>

                <!-- Validation Summary -->
                <VBox styleClass="validation-container">
                    <Label fx:id="validationSummary" styleClass="error-label-small" visible="false" wrapText="true"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>

    <!-- Enhanced Action Buttons -->
    <HBox spacing="15" alignment="CENTER_RIGHT" styleClass="form-actions" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0; -fx-padding: 20;">
        <Button text="Réinitialiser" onAction="#resetForm" styleClass="btn-secondary-small" style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-font-weight: 500; -fx-pref-width: 100;"/>
        <Button text="Dupliquer" onAction="#duplicateProduct" styleClass="btn-info-small" style="-fx-background-color: #06b6d4; -fx-text-fill: white; -fx-font-weight: 500; -fx-pref-width: 100;"/>
        <Button text="Supprimer" onAction="#deleteProduct" styleClass="btn-danger-small" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: 500; -fx-pref-width: 100;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Annuler" onAction="#close" styleClass="btn-secondary-small" style="-fx-background-color: #94a3b8; -fx-text-fill: white; -fx-font-weight: 500; -fx-pref-width: 100;"/>
        <Button fx:id="btnSave" text="Mettre à jour" onAction="#updateProduit" styleClass="btn-primary-small" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: 600; -fx-pref-width: 120;"/>
    </HBox>

</VBox>
