<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.formini.controllers.CloudinaryFXController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    <children>
        <Label text="Test Upload Cloudinary">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        
        <TextField fx:id="nomField" promptText="Nom du produit" style="-fx-pref-width: 300;" />
        
        <TextArea fx:id="descField" prefHeight="80.0" prefWidth="300.0" promptText="Description du produit" />
        
        <Button mnemonicParsing="false" onAction="#handleChooseImage" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="1. Choisir une image" />
        
        <ImageView fx:id="previewImage" fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 0);" />
        
        <Button mnemonicParsing="false" onAction="#handleSave" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;" text="2. Sauvegarder (Cloud + DB)" />
        
        <Label fx:id="urlLabel" text="En attente de sélection..." textAlignment="CENTER" wrapText="true" />
    </children>
</VBox>
