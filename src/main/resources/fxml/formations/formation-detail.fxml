<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.formini.controllers.formations.FormationDetailController"
      spacing="12" style="-fx-background-color: white; -fx-padding: 16;">

    <children>
        <Label fx:id="titreLabel" text="Titre" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

        <HBox spacing="16" alignment="TOP_LEFT">
            <children>
                <ImageView fx:id="coverImageView" fitWidth="300" fitHeight="180" preserveRatio="false" smooth="true"/>

                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="categorieLabel" text="Categorie:"/>
                        <Label fx:id="niveauLabel" text="Niveau:"/>
                        <Label fx:id="langueLabel" text="Langue:"/>
                        <Label fx:id="dureeLabel" text="Duree:"/>
                        <Label fx:id="prixLabel" text="Prix:"/>
                        <Label fx:id="statutInscriptionLabel" text="Statut inscription" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    </children>
                </VBox>
            </children>
        </HBox>

        <Label text="Description" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
        <ScrollPane fitToWidth="true" prefHeight="220">
            <content>
                <Label fx:id="descriptionLabel" wrapText="true" style="-fx-padding: 8;"/>
            </content>
        </ScrollPane>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <children>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="S'inscrire" fx:id="inscriptionButton" onAction="#handleInscription"
                        style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button text="Commencer" fx:id="commencerButton" onAction="#handleCommencer"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button text="Fermer" onAction="#handleClose"/>
            </children>
            <padding>
                <Insets top="6"/>
            </padding>
        </HBox>
    </children>
</VBox>

