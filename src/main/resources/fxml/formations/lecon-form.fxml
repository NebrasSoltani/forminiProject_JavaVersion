<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.formini.controllers.formations.LeconFormController"
      spacing="12" style="-fx-padding: 16; -fx-background-color: white;">

    <children>
        <Label fx:id="titleLabel" text="Creer une lecon" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints minWidth="130" prefWidth="150"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <children>
                <Label text="Titre*" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="titreField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Description" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextArea fx:id="descriptionArea" prefRowCount="3" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Contenu" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextArea fx:id="contenuArea" prefRowCount="4" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Ordre*" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="ordreField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="Duree (min)" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="dureeField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                <Label text="Video URL" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <TextField fx:id="videoUrlField" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                <Label text="Fichier" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <TextField fx:id="fichierField" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                <Label text="Gratuit" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                <CheckBox fx:id="gratuitCheck" GridPane.rowIndex="7" GridPane.columnIndex="1"/>
            </children>
        </GridPane>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <children>
                <Button text="Annuler" onAction="#handleCancel"/>
                <Button text="Enregistrer" onAction="#handleSave"
                        style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </children>
        </HBox>
    </children>
</VBox>

