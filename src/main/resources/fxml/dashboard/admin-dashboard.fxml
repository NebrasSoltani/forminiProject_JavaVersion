<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.formini.controllers.dashboard.AdminDashboardController" spacing="20" style="-fx-padding: 20;">
    <children>
        <!-- Title -->
        <Label fx:id="titleLabel" text="Tableau de Bord Administrateur" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        
        <!-- Statistics Section -->
        <VBox spacing="10" style="-fx-background-color: #ecf0f1; -fx-padding: 15; -fx-border-radius: 5;">
            <children>
                <Label text="Statistiques du Système" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <Label fx:id="statsLabel" text="Chargement..." style="-fx-font-size: 14px;"/>
            </children>
        </VBox>
        
        <!-- Management Menu -->
        <VBox spacing="15">
            <children>
                <Label text="Gestion du Système" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                
                <GridPane hgap="15" vgap="15">
                    <children>
                        <Button fx:id="apprenantsManagementButton" text="Gestion des Apprenants" 
                                style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-pref-width: 200; -fx-pref-height: 50;" 
                                GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        
                        <Button fx:id="formateursManagementButton" text="Gestion des Formateurs" 
                                style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-pref-width: 200; -fx-pref-height: 50;" 
                                GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        
                        <Button fx:id="societesManagementButton" text="Gestion des Sociétés" 
                                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-pref-width: 200; -fx-pref-height: 50;" 
                                GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        
                        <Button fx:id="eventsManagementButton" text="Gestion des Événements" 
                                style="-fx-background-color: #1abc9c; -fx-text-fill: white; -fx-pref-width: 200; -fx-pref-height: 50;" 
                                GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        
                        <Button fx:id="formationsManagementButton" text="Gestion des Formations" 
                                style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-pref-width: 200; -fx-pref-height: 50;" 
                                GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        
                        <Button fx:id="reportsButton" text="Rapports et Statistiques" 
                                style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-pref-width: 200; -fx-pref-height: 50;" 
                                GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    </children>
                </GridPane>
            </children>
        </VBox>
        
        <!-- Quick Actions -->
        <VBox spacing="10" style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-border-radius: 5;">
            <children>
                <Label text="Actions Rapides" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <HBox spacing="10">
                    <children>
                        <Button text="Actualiser" onAction="#refreshDashboard" style="-fx-background-color: #95a5a6; -fx-text-fill: white;"/>
                        <Button text="Sauvegarder" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
                        <Button text="Paramètres" style="-fx-background-color: #7f8c8d; -fx-text-fill: white;"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
