<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.formini.controllers.dashboard.ApprenantDashboardController" spacing="20" style="-fx-padding: 20; -fx-background-color: #f5f6fa;">
    <children>
        <!-- Title -->
        <Label fx:id="titleLabel" text="Tableau de Bord Apprenant" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        
        <!-- Welcome Message -->
        <Label fx:id="welcomeLabel" text="Bienvenue!" style="-fx-font-size: 18px; -fx-text-fill: #34495e;"/>
        
        <!-- Statistics Cards -->
        <HBox spacing="20" alignment="CENTER">
            <children>
                <VBox prefWidth="260" prefHeight="100" style="-fx-background-color: #3498db; -fx-background-radius: 12; -fx-border-radius: 12; -fx-padding: 20;" alignment="CENTER">
                    <children>
                        <Label text="Mes Formations" style="-fx-font-size: 14px; -fx-text-fill: white;"/>
                        <Label fx:id="lblTotalFormations" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    </children>
                </VBox>
                <VBox prefWidth="260" prefHeight="100" style="-fx-background-color: #2ecc71; -fx-background-radius: 12; -fx-border-radius: 12; -fx-padding: 20;" alignment="CENTER">
                    <children>
                        <Label text="Quiz Completes" style="-fx-font-size: 14px; -fx-text-fill: white;"/>
                        <Label fx:id="lblQuizCompletes" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    </children>
                </VBox>
                <VBox prefWidth="260" prefHeight="100" style="-fx-background-color: #f39c12; -fx-background-radius: 12; -fx-border-radius: 12; -fx-padding: 20;" alignment="CENTER">
                    <children>
                        <Label text="Offres de Stage" style="-fx-font-size: 14px; -fx-text-fill: white;"/>
                        <Label fx:id="lblOffresStage" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    </children>
                </VBox>
                <VBox prefWidth="260" prefHeight="100" style="-fx-background-color: #9b59b6; -fx-background-radius: 12; -fx-border-radius: 12; -fx-padding: 20;" alignment="CENTER">
                    <children>
                        <Label text="Certificats" style="-fx-font-size: 14px; -fx-text-fill: white;"/>
                        <Label fx:id="lblCertificats" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- Menu Buttons -->
        <VBox spacing="15">
            <children>
                <Label text="Mon Apprentissage" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                
                <GridPane hgap="15" vgap="15">
                    <children>
                        <Button fx:id="viewFormationsButton" text="Catalogue des Formations" 
                                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-pref-width: 200; -fx-pref-height: 50; -fx-cursor: hand; -fx-border-radius: 8; -fx-background-radius: 8;" 
                                GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        
                        <Button fx:id="myInscriptionsButton" text="Mes Inscriptions" 
                                style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-pref-width: 200; -fx-pref-height: 50; -fx-cursor: hand; -fx-border-radius: 8; -fx-background-radius: 8;" 
                                GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        
                        <Button fx:id="myProgressButton" text="Ma Progression" 
                                style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-pref-width: 200; -fx-pref-height: 50; -fx-cursor: hand; -fx-border-radius: 8; -fx-background-radius: 8;" 
                                GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        
                        <Button fx:id="takeQuizButton" text="Passer un Quiz" 
                                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-pref-width: 200; -fx-pref-height: 50; -fx-cursor: hand; -fx-border-radius: 8; -fx-background-radius: 8;" 
                                GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        
                        <Button fx:id="myCertificatesButton" text="Mes Certificats" 
                                style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-pref-width: 200; -fx-pref-height: 50; -fx-cursor: hand; -fx-border-radius: 8; -fx-background-radius: 8;" 
                                GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        
                        <Button fx:id="profileButton" text="Mon Profil" 
                                style="-fx-background-color: #1abc9c; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-pref-width: 200; -fx-pref-height: 50; -fx-cursor: hand; -fx-border-radius: 8; -fx-background-radius: 8;" 
                                GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Button fx:id="viewOffersButton" text="Offres de Stage"
                                style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-pref-width: 200; -fx-pref-height: 50; -fx-cursor: hand; -fx-border-radius: 8; -fx-background-radius: 8;"
                                GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    </children>
                </GridPane>
            </children>
        </VBox>
        
        <!-- Stats Label -->
        <Label fx:id="statsLabel" text="Chargement..." style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
        
        <!-- Quick Actions -->
        <HBox spacing="10">
            <children>
                <Button text="Actualiser" onAction="#refreshDashboard" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 13px; -fx-cursor: hand; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15 8 15;"/>
                <Button text="Aide" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 13px; -fx-cursor: hand; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15 8 15;"/>
                <Button text="Parametres" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-size: 13px; -fx-cursor: hand; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15 8 15;"/>
            </children>
        </HBox>
    </children>
</VBox>