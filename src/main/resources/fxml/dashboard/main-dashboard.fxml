<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.formini.controllers.dashboard.DashboardController" spacing="10" style="-fx-padding: 20;">
    <children>
        <!-- Header with user info and logout -->
        <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-background-color: #f0f0f0; -fx-padding: 10;">
            <children>
                <VBox spacing="5">
                    <children>
                        <Label fx:id="welcomeLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                        <Label fx:id="userRoleLabel" style="-fx-font-size: 14px;"/>
                        <Label fx:id="userInfoLabel" style="-fx-font-size: 12px;"/>
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Mon Profil" onAction="#handleProfile"/>
                <Button text="Déconnexion" onAction="#handleLogout" style="-fx-background-color: #ff6b6b; -fx-text-fill: white;"/>
            </children>
        </HBox>
        
        <!-- Dynamic content area for role-specific dashboard -->
        <VBox fx:id="contentArea" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 5;">
            <!-- Role-specific dashboard content will be loaded here -->
        </VBox>
    </children>
</VBox>
