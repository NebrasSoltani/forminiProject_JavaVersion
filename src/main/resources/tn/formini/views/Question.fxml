<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.formini.controllers.QuestionController"
      spacing="20" style="-fx-background-color: #1a1a2e; -fx-padding: 30;">

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="❓ Gestion des Questions" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Nouvelle Question" onAction="#ouvrirFormAjout"
                style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍 Rechercher..."
                   onKeyReleased="#filtrerQuestions" prefWidth="300"
                   style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-prompt-text-fill: #a8a8b3; -fx-padding: 10 15; -fx-background-radius: 8; -fx-border-color: #0f3460; -fx-border-radius: 8;"/>
        <ComboBox fx:id="filtreQuiz" promptText="Filtrer par Quiz" onAction="#filtrerQuestions"
                  style="-fx-background-color: #16213e; -fx-border-color: #0f3460; -fx-border-radius: 8;"/>
    </HBox>

    <TableView fx:id="tableQuestion" VBox.vgrow="ALWAYS"
               style="-fx-background-color: #16213e; -fx-border-color: #0f3460; -fx-border-radius: 10;">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colEnonce" text="Énoncé" prefWidth="250"/>
            <TableColumn fx:id="colType" text="Type" prefWidth="100"/>
            <TableColumn fx:id="colPoints" text="Points" prefWidth="70"/>
            <TableColumn fx:id="colOrdre" text="Ordre" prefWidth="60"/>
            <TableColumn fx:id="colQuiz" text="Quiz" prefWidth="130"/>
            <TableColumn fx:id="colActions" text="Actions" prefWidth="150"/>
        </columns>
        <placeholder>
            <Label text="Aucune question trouvée" style="-fx-text-fill: #a8a8b3;"/>
        </placeholder>
    </TableView>

</VBox>
