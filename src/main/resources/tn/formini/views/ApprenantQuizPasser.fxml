<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.formini.controllers.ApprenantQuizPasserController"
      spacing="15" style="-fx-background-color: #1a1a2e; -fx-padding: 30;">

    <HBox alignment="CENTER_LEFT">
        <Label fx:id="quizTitleLabel" text="Quiz Title" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="timerLabel" text="Temps: --:--" style="-fx-text-fill: #e94560; -fx-font-size: 16px; -fx-font-weight: bold;"/>
    </HBox>

    <Label fx:id="progressLabel" text="Question 1/X" style="-fx-text-fill: #a8a8b3;"/>

    <VBox style="-fx-background-color: #16213e; -fx-padding: 20; -fx-border-color: #0f3460; -fx-border-radius: 8; -fx-background-radius: 8;" spacing="15" VBox.vgrow="ALWAYS">
        <Label fx:id="questionEnonceLabel" text="Énoncé de la question..." wrapText="true" style="-fx-text-fill: white; -fx-font-size: 16px;"/>
        
        <VBox fx:id="reponsesContainer" spacing="10" VBox.vgrow="ALWAYS">
            <!-- RadioButtons for answers will go here -->
        </VBox>
    </VBox>

    <!-- Error/warning label -->
    <Label fx:id="errorLabel" text="" style="-fx-text-fill: #e94560; -fx-font-size: 14px;" wrapText="true"/>

    <!-- Results panel (hidden by default) -->
    <VBox fx:id="resultBox" spacing="10" visible="false" managed="false" style="-fx-background-color: #0f3460; -fx-padding: 20; -fx-background-radius: 8;">
        <Label fx:id="resultTitleLabel" text="Résultat" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Label fx:id="resultNoteLabel" text="Note: 0%" style="-fx-text-fill: #e94560; -fx-font-size: 16px;"/>
        <Label fx:id="resultBonnesLabel" text="Bonnes réponses : 0/0" style="-fx-text-fill: white;"/>
    </VBox>

    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button text="Fermer" onAction="#fermer"
                style="-fx-background-color: #2d2d44; -fx-text-fill: #a8a8b3; -fx-padding: 10 25; -fx-background-radius: 8; -fx-cursor: hand;"/>
        
        <Button fx:id="btnPrecedent" text="Précédent" onAction="#questionPrecedente" visible="false" managed="false"
                style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-padding: 10 25; -fx-background-radius: 8; -fx-cursor: hand;"/>
                
        <Button fx:id="btnSuivant" text="Suivant" onAction="#questionSuivante"
                style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-padding: 10 25; -fx-background-radius: 8; -fx-cursor: hand;"/>

        <Button fx:id="btnSoumettre" text="Soumettre" onAction="#soumettreQuiz" visible="false" managed="false"
                style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 8; -fx-cursor: hand;"/>
    </HBox>

</VBox>
