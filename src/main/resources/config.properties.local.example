# Configuration OpenAI API
# Copy this file to config.properties.local and add your actual API key
openai.api.key=your-openai-api-key-here

# Configuration des services IA
ai.service.enabled=true
ai.suggestions.max_results=5
ai.search.timeout=30000

# Configuration du modèle
ai.model=gpt-3.5-turbo
ai.temperature=0.7
ai.max_tokens=150

# Configuration de l'interface
ui.suggestions.auto_refresh=false
ui.suggestions.cache_duration=300
